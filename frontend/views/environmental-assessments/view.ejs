<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="p-4 mb-4 rounded-3" style="background: linear-gradient(135deg, #198754, #0d6efd); color: white;">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h3 class="fw-bold mb-1"><i class="fas fa-leaf me-2"></i><%= assessment.title %></h3>
        <p class="mb-0 opacity-75">
          Assessment #<%= assessment.assessmentNumber || 'N/A' %> |
          <%= assessment.workArea?.name || 'Work area' %>
        </p>
      </div>
      <span class="badge <%= assessment.officerReview?.status === 'approved' ? 'bg-success' : 'bg-warning text-dark' %> px-3 py-2">
        <%= assessment.officerReview?.status === 'approved' ? 'APPROVED' : 'DRAFT' %>
      </span>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <h5 class="fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Executive Summary</h5>
          <div class="p-3 bg-light rounded mb-4">
            <p class="mb-0"><%= assessment.aiSummary?.executiveSummary || 'No summary provided.' %></p>
          </div>

          <h5 class="fw-bold text-danger"><i class="fas fa-triangle-exclamation me-2"></i>Key Risks</h5>
          <div class="p-3 bg-light rounded mb-4">
            <ul class="mb-0">
              <% (assessment.aiSummary?.keyRisks || []).forEach(item => { %>
                <li class="mb-2"><%= item %></li>
              <% }) %>
            </ul>
          </div>

          <h5 class="fw-bold text-success"><i class="fas fa-list-check me-2"></i>Recommended Actions</h5>
          <div class="p-3 bg-light rounded">
            <ul class="mb-0">
              <% (assessment.aiSummary?.recommendedActions || []).forEach(item => { %>
                <li class="mb-2"><%= item %></li>
              <% }) %>
            </ul>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white">
          <h5 class="mb-0 fw-bold"><i class="fas fa-table-list me-2 text-primary"></i>Impact Register</h5>
        </div>
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead class="table-light">
              <tr><th>Impact</th><th>Receptor</th><th>Severity</th><th>Risk</th><th>Mitigation</th></tr>
            </thead>
            <tbody>
              <% (assessment.impacts || []).forEach(impact => { %>
                <tr>
                  <td><%= impact.impact %></td>
                  <td><%= impact.receptor || 'N/A' %></td>
                  <td><%= impact.severity %></td>
                  <td>
                    <span class="badge bg-<%= impact.riskLevel === 'critical' ? 'danger' : impact.riskLevel === 'high' ? 'warning text-dark' : 'secondary' %>">
                      <%= impact.riskLevel %>
                    </span>
                  </td>
                  <td><%= (impact.mitigationMeasures || []).join('; ') || 'N/A' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <%- include('../partials/ai-review-panel', { record: assessment, basePath: '/environmental-assessments' }) %>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="fas fa-cog me-2 text-primary"></i>Actions</h6>
          <% if (assessment.officerReview?.status === 'approved') { %>
            <a href="/environmental-assessments/<%= assessment._id %>/download-word" class="btn btn-success w-100">
              <i class="fas fa-file-word me-2"></i>Download Word Document
            </a>
          <% } else { %>
            <div class="alert alert-warning py-2 mb-0"><i class="fas fa-lock me-1"></i>Download unlocks after final approval.</div>
          <% } %>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="fas fa-info-circle me-2 text-primary"></i>Assessment Information</h6>
          <table class="table table-sm mb-0">
            <tr><td><strong>Number:</strong></td><td>#<%= assessment.assessmentNumber || 'N/A' %></td></tr>
            <tr><td><strong>Work Area:</strong></td><td><%= assessment.workArea?.name || 'N/A' %></td></tr>
            <tr><td><strong>Version:</strong></td><td><%= assessment.version || 1 %></td></tr>
            <tr><td><strong>Status:</strong></td><td><%= assessment.officerReview?.status || 'pending' %></td></tr>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
