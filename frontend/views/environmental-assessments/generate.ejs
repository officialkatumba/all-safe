<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h3 class="fw-bold mb-1">Environmental Screening</h3>
          <p class="text-muted mb-0"><%= workArea.name %> · <%= workArea.worksite?.name || 'Worksite' %></p>
        </div>
        <a href="/work-areas/<%= workArea._id %>" class="btn btn-outline-secondary btn-sm">Back</a>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <form method="POST" action="/environmental-assessments/generate/<%= workArea._id %>">
            <div class="mb-3">
              <label class="form-label fw-semibold">Title</label>
              <input type="text" name="title" class="form-control" value="Environmental Screening - <%= workArea.name %>">
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Activity Description</label>
              <textarea name="activityDescription" class="form-control" rows="8" required placeholder="Describe the activity, equipment, materials, location, nearby receptors, and any known environmental concerns."></textarea>
              <div class="form-text">The AI will use this plus existing worksite/work-area data to draft an impact register for review.</div>
            </div>
            <button type="submit" class="btn btn-success">
              <i class="fas fa-leaf me-1"></i> Generate Screening Draft
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
