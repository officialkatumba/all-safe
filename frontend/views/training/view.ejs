<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<%
  const recommendedTrainingsList = training.recommendedTrainings || [];
  const trainingChecklistList = training.trainingChecklist || [];
%>

<div class="container py-4">
  <div class="p-4 mb-4 rounded-3" style="background: linear-gradient(135deg, #667eea, #764ba2); color: white;">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="d-flex align-items-center gap-2 mb-2">
          <i class="fas fa-graduation-cap fa-2x text-white"></i>
          <h3 class="fw-bold mb-0">Training Requirements</h3>
        </div>

        <p class="mb-0 opacity-75">
          Requirement #<%= training.requirementNumber || 'N/A' %> |
          <%= training.generatedDate ? new Date(training.generatedDate).toLocaleDateString() : 'N/A' %>
        </p>
      </div>

      <div class="text-end">
        <span class="badge bg-light text-dark px-3 py-2">
          <i class="fas fa-robot me-1"></i>
          AI Generated
        </span>

        <span class="badge <%= 
          training.priority === 'critical' ? 'bg-danger' :
          training.priority === 'high' ? 'bg-warning text-dark' :
          training.priority === 'medium' ? 'bg-info' :
          'bg-secondary'
        %> px-3 py-2 ms-2">
          <%= training.priority?.toUpperCase() || 'MEDIUM' %>
        </span>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-3">
            <i class="fas fa-chalkboard-user me-2 text-primary"></i>
            <%= training.title || 'AI Recommended Training' %>
          </h4>

          <div class="alert alert-info border-info">
            <i class="fas fa-circle-info me-2"></i>
            This page displays the AI-recommended training for this work area. Use the Word download button to get an editable training checklist that the safety officer can print, tick, sign, and file.
          </div>

          <% if (training.description) { %>
            <div class="mb-4">
              <h5 class="fw-bold">
                <i class="fas fa-align-left me-2 text-primary"></i>
                Training Overview
              </h5>
              <p class="text-muted"><%= training.description %></p>
            </div>
          <% } %>

          <h5 class="fw-bold mt-4 mb-3">
            <i class="fas fa-list-check me-2 text-success"></i>
            AI-Recommended Training List
          </h5>

          <% if (recommendedTrainingsList.length > 0) { %>
            <div class="row g-3">
              <% recommendedTrainingsList.forEach(item => { %>
                <div class="col-md-6">
                  <div class="training-card h-100 border rounded-3 p-3 bg-light">
                    <div class="d-flex align-items-start gap-3">
                      <div class="training-icon">
                        <i class="fas fa-graduation-cap"></i>
                      </div>

                      <div class="flex-grow-1">
                        <h6 class="fw-bold mb-1">
                          <%= item.trainingTitle || 'Recommended Training' %>
                        </h6>

                        <div class="small text-muted mb-2">
                          <i class="fas fa-clock me-1"></i>
                          Duration:
                          <strong><%= item.duration || 'To be determined' %></strong>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-2">
                          <span class="badge <%= 
                            item.priority === 'critical' ? 'bg-danger' :
                            item.priority === 'high' ? 'bg-warning text-dark' :
                            item.priority === 'medium' ? 'bg-info' :
                            'bg-secondary'
                          %>">
                            <%= item.priority || 'medium' %>
                          </span>

                          <span class="badge bg-light text-dark border">
                            <%= String(item.category || 'training').replace(/_/g, ' ') %>
                          </span>
                        </div>

                        <% if (item.reason) { %>
                          <p class="small text-muted mb-2">
                            <i class="fas fa-circle-info me-1 text-primary"></i>
                            <%= item.reason %>
                          </p>
                        <% } %>

                        <% if (item.targetRoles && item.targetRoles.length > 0) { %>
                          <div class="small text-muted">
                            <i class="fas fa-users me-1"></i>
                            <%= item.targetRoles.join(', ') %>
                          </div>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="p-3 bg-light rounded">
              <h6 class="fw-bold"><%= training.title %></h6>
              <p class="text-muted mb-0"><%= training.description || 'No specific training list was generated.' %></p>
            </div>
          <% } %>

          <% if (training.learningObjectives && training.learningObjectives.length > 0) { %>
            <h5 class="fw-bold mt-5 mb-3">
              <i class="fas fa-bullseye me-2 text-warning"></i>
              Learning Objectives
            </h5>

            <ul class="list-group mb-4">
              <% training.learningObjectives.forEach(obj => { %>
                <li class="list-group-item">
                  <i class="fas fa-check-circle text-success me-2"></i>
                  <%= obj %>
                </li>
              <% }) %>
            </ul>
          <% } %>

          <% if (training.keyTopics && training.keyTopics.length > 0) { %>
            <h5 class="fw-bold mt-4 mb-3">
              <i class="fas fa-book-open me-2 text-info"></i>
              Key Topics
            </h5>

            <div class="d-flex flex-wrap gap-2">
              <% training.keyTopics.forEach(topic => { %>
                <span class="badge bg-light text-dark border p-2">
                  <i class="fas fa-tag me-1"></i>
                  <%= topic %>
                </span>
              <% }) %>
            </div>
          <% } %>

          <div class="mt-5 p-4 rounded-3" style="background: linear-gradient(135deg, #eef1ff, #f8f9fa); border-left: 5px solid #667eea;">
            <h5 class="fw-bold text-primary">
              <i class="fas fa-file-word me-2"></i>
              Editable Word Training Checklist Available
            </h5>

            <p class="mb-3 text-muted">
              The downloadable Word document includes a printable checklist with tick boxes for safety officer verification.
            </p>

            <p class="small text-muted mb-0">
              The approved Word checklist is available from the actions panel.
            </p>
          </div>
        </div>
      </div>

      <%- include('../partials/ai-review-panel', { record: training, basePath: '/training' }) %>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <h6 class="fw-bold mb-3">
            <i class="fas fa-cog me-2 text-primary"></i>
            Actions
          </h6>

          <div class="d-grid gap-2">
            <% if (training.officerReview?.status === 'approved') { %>
              <a href="/training/<%= training._id %>/download-word" class="btn btn-primary">
                <i class="fas fa-file-word me-2"></i>
                Download Word Checklist
              </a>
            <% } %>

          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <h6 class="fw-bold mb-3">
            <i class="fas fa-info-circle me-2 text-primary"></i>
            Training Information
          </h6>

          <table class="table table-sm">
            <tr>
              <td><strong>Requirement No:</strong></td>
              <td>#<%= training.requirementNumber || 'N/A' %></td>
            </tr>

            <tr>
              <td><strong>Work Area:</strong></td>
              <td><%= training.workArea?.name || 'N/A' %></td>
            </tr>

            <tr>
              <td><strong>Category:</strong></td>
              <td><%= String(training.category || 'N/A').replace(/_/g, ' ') %></td>
            </tr>

            <tr>
              <td><strong>Priority:</strong></td>
              <td>
                <span class="badge <%= 
                  training.priority === 'critical' ? 'bg-danger' :
                  training.priority === 'high' ? 'bg-warning text-dark' :
                  training.priority === 'medium' ? 'bg-info' :
                  'bg-secondary'
                %>">
                  <%= training.priority || 'medium' %>
                </span>
              </td>
            </tr>

            <tr>
              <td><strong>Duration:</strong></td>
              <td><%= training.duration || 'N/A' %></td>
            </tr>

            <tr>
              <td><strong>Refresher:</strong></td>
              <td><%= training.refresherFrequency || 'N/A' %></td>
            </tr>

            <tr>
              <td><strong>Training Items:</strong></td>
              <td><%= recommendedTrainingsList.length || 1 %></td>
            </tr>

            <tr>
              <td><strong>Checklist Items:</strong></td>
              <td><%= trainingChecklistList.length %></td>
            </tr>
          </table>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h6 class="fw-bold mb-2">
            <i class="fas fa-user-shield me-2 text-primary"></i>
            Human Verification
          </h6>

          <p class="small text-muted mb-0">
            AI recommends the training, but the safety officer should use the downloaded Word checklist to verify that training was delivered, understood, recorded, and signed off.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .training-card {
    transition: all 0.2s ease;
  }

  .training-card:hover {
    background: #ffffff !important;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .training-icon {
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 50%;
    background: #667eea;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media print {
    .navbar,
    .btn,
    form {
      display: none !important;
    }

    .card {
      border: none !important;
      box-shadow: none !important;
    }
  }
</style>

<%- include('../partials/footer') %>
