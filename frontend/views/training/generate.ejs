<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="card shadow-lg border-0" style="border-radius: 20px;">
    <div class="card-header" style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; border-radius: 20px 20px 0 0;">
      <h4 class="mb-0">
        <i class="fas fa-graduation-cap me-2"></i>
        Generate Training Requirement
      </h4>
      <p class="mb-0 small opacity-75">Work Area: <%= workArea.name %></p>
    </div>

    <div class="card-body p-4">
      <div class="alert alert-info mb-4">
        <i class="fas fa-robot me-2"></i>
        <strong>AI-Powered Training Generation</strong><br>
        AI will analyze work area hazards, incidents, observations, and risk assessments to recommend the training needed for this work area.
      </div>

      <form method="POST">
        <div class="mb-4">
          <label class="form-label fw-bold">
            Training Categories
          </label>

          <div class="form-text mb-2">
            Tick one or more categories, or leave all unchecked and allow AI to decide from the safety data.
          </div>

          <div class="row g-2">
            <% categories.forEach(cat => { %>
              <div class="col-md-6">
                <label class="border rounded-3 p-3 d-flex align-items-center gap-2 category-option h-100">
                  <input
                    type="checkbox"
                    name="categories"
                    value="<%= cat.value %>"
                    class="form-check-input"
                  >
                  <span>
                    <strong><%= cat.label %></strong>
                  </span>
                </label>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Custom Title / Focus Area (Optional)</label>
          <input
            type="text"
            name="title"
            class="form-control"
            placeholder="e.g., Confined Space Entry Training, Working at Heights, Fire Response"
          >
          <div class="form-text">Leave blank for an AI-generated title.</div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">Priority Level</label>
          <select name="priority" class="form-select" style="border-radius: 40px;">
            <option value="critical">Critical - Immediate</option>
            <option value="high">High - Within 2 weeks</option>
            <option value="medium" selected>Medium - Within 30 days</option>
            <option value="low">Low - Within 90 days</option>
          </select>
        </div>

        <div class="d-flex justify-content-between gap-3 mt-4">
          <a href="/work-areas/<%= workArea._id %>" class="btn btn-outline-secondary px-4">
            <i class="fas fa-times me-2"></i>
            Cancel
          </a>

          <button type="submit" class="btn btn-primary px-5">
            <i class="fas fa-magic me-2"></i>
            Generate Training
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .category-option {
    cursor: pointer;
    background: #f8f9fa;
    transition: all 0.2s ease;
  }

  .category-option:hover {
    background: #eef1ff;
    border-color: #667eea !important;
  }

  .category-option input:checked + span {
    color: #667eea;
  }
</style>

<%- include('../partials/footer') %>
