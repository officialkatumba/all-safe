<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
      <h2 class="fw-bold mb-1"><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Incident Reports</h2>
      <p class="text-muted">Manage and investigate all reported incidents, near misses, and hazards</p>
    </div>
    <div class="dropdown">
      <button class="btn btn-danger dropdown-toggle" type="button" data-bs-toggle="dropdown">
        <i class="fas fa-flag me-1"></i> Report Incident
      </button>
      <ul class="dropdown-menu">
        <% if (workAreas && workAreas.length > 0) { %>
          <% workAreas.forEach(wa => { %>
            <li><a class="dropdown-item" href="/incidents/report/<%= wa._id %>"><%= wa.name %></a></li>
          <% }) %>
        <% } else { %>
          <li><a class="dropdown-item disabled" href="#">No work areas assigned</a></li>
        <% } %>
      </ul>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-danger text-white">
        <div class="card-body py-3">
          <h3 class="mb-0 fw-bold"><%= stats.total || 0 %></h3>
          <small>Total Reports</small>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-warning text-dark">
        <div class="card-body py-3">
          <h3 class="mb-0 fw-bold"><%= stats.pending || 0 %></h3>
          <small>Pending Review</small>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-info text-white">
        <div class="card-body py-3">
          <h3 class="mb-0 fw-bold"><%= stats.investigating || 0 %></h3>
          <small>Investigating</small>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-success text-white">
        <div class="card-body py-3">
          <h3 class="mb-0 fw-bold"><%= stats.resolved || 0 %></h3>
          <small>Resolved</small>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-primary text-white">
        <div class="card-body py-3">
          <h3 class="mb-0 fw-bold"><%= stats.incidents || 0 %></h3>
          <small>Incidents</small>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-secondary text-white">
        <div class="card-body py-3">
          <h3 class="mb-0 fw-bold"><%= stats.nearMisses || 0 %></h3>
          <small>Near Misses</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="card shadow-sm mb-4 border-0">
    <div class="card-body">
      <form method="GET" class="row g-3">
        <div class="col-md-3">
          <select name="status" class="form-select">
            <option value="all">All Status</option>
            <option value="reported" <%= filters.status === 'reported' ? 'selected' : '' %>>Reported</option>
            <option value="under_investigation" <%= filters.status === 'under_investigation' ? 'selected' : '' %>>Under Investigation</option>
            <option value="action_taken" <%= filters.status === 'action_taken' ? 'selected' : '' %>>Action Taken</option>
            <option value="resolved" <%= filters.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
            <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
          </select>
        </div>
        <div class="col-md-3">
          <select name="type" class="form-select">
            <option value="all">All Types</option>
            <option value="incident" <%= filters.type === 'incident' ? 'selected' : '' %>>Incident</option>
            <option value="near_miss" <%= filters.type === 'near_miss' ? 'selected' : '' %>>Near Miss</option>
            <option value="hazard_observation" <%= filters.type === 'hazard_observation' ? 'selected' : '' %>>Hazard Observation</option>
          </select>
        </div>
        <div class="col-md-3">
          <select name="severity" class="form-select">
            <option value="all">All Severity</option>
            <option value="low" <%= filters.severity === 'low' ? 'selected' : '' %>>Low</option>
            <option value="medium" <%= filters.severity === 'medium' ? 'selected' : '' %>>Medium</option>
            <option value="high" <%= filters.severity === 'high' ? 'selected' : '' %>>High</option>
            <option value="critical" <%= filters.severity === 'critical' ? 'selected' : '' %>>Critical</option>
          </select>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Incidents Table -->
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Type</th>
              <th>Severity</th>
              <th>Description</th>
              <th>Location</th>
              <th>Date</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (incidents && incidents.length > 0) { %>
              <% incidents.forEach(incident => { %>
              <tr>
                <td class="fw-bold">INC-<%= incident.incidentNumber %></td>
                <td>
                  <span class="badge <%= incident.type === 'incident' ? 'bg-danger' : incident.type === 'near_miss' ? 'bg-warning text-dark' : 'bg-info' %>">
                    <%= incident.type === 'near_miss' ? 'Near Miss' : (incident.type === 'hazard_observation' ? 'Hazard' : 'Incident') %>
                  </span>
                </td>
                <td>
                  <span class="badge <%= 
                    incident.severity === 'critical' ? 'bg-danger' : 
                    incident.severity === 'high' ? 'bg-warning text-dark' : 
                    incident.severity === 'medium' ? 'bg-info' : 
                    'bg-success' 
                  %>">
                    <%= incident.severity?.toUpperCase() %>
                  </span>
                </td>
                <td><%= incident.description?.substring(0, 60) %>...</td>
                <td><%= incident.location %></td>
                <td><%= new Date(incident.dateTime).toLocaleDateString() %></td>
                <td>
                  <span class="badge <%= 
                    incident.status === 'closed' ? 'bg-success' : 
                    incident.status === 'resolved' ? 'bg-primary' : 
                    incident.status === 'under_investigation' ? 'bg-warning text-dark' : 
                    'bg-secondary' 
                  %>">
                    <%= incident.status?.replace('_', ' ') %>
                  </span>
                </td>
                <td>
                  <a href="/incidents/<%= incident._id %>" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-eye"></i>
                  </a>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="8" class="text-center py-5 text-muted">
                  <i class="fas fa-check-circle fa-3x mb-3"></i>
                  <p>No incidents reported. Keep up the good work!</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Pagination -->
  <% if (pagination && pagination.pages > 1) { %>
  <div class="d-flex justify-content-center mt-4">
    <nav>
      <ul class="pagination">
        <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= pagination.page - 1 %>&status=<%= filters.status %>&type=<%= filters.type %>&severity=<%= filters.severity %>">Previous</a>
        </li>
        <% for (let i = 1; i <= pagination.pages; i++) { %>
          <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= i %>&status=<%= filters.status %>&type=<%= filters.type %>&severity=<%= filters.severity %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= pagination.page + 1 %>&status=<%= filters.status %>&type=<%= filters.type %>&severity=<%= filters.severity %>">Next</a>
        </li>
      </ul>
    </nav>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>