<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <!-- Header -->
  <div class="p-4 mb-4 rounded-3" style="background: linear-gradient(135deg, #5f2c82, #49a09d)">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <div class="d-flex align-items-center gap-2 mb-2">
          <i class="fas fa-chalkboard-teacher fa-2x text-white"></i>
          <h2 class="text-white fw-bold mb-0"><%= talk.title %></h2>
        </div>
        <p class="text-white-50 mb-0">
          Talk #<%= talk.talkNumber %> | 
          <%= talk.targetWorkAreas.map(wa => wa.name).join(", ") %> |
          <%= new Date(talk.date).toLocaleDateString() %>
        </p>
      </div>
      <div>
        <span class="badge bg-light text-dark px-3 py-2">
          <i class="fas fa-clock me-1"></i> <%= talk.duration %> min
        </span>
        <span class="badge <%= talk.status === 'published' ? 'bg-success' : talk.status === 'draft' ? 'bg-warning text-dark' : 'bg-primary' %> ms-2 px-3 py-2">
          <i class="fas fa-<%= talk.status === 'published' ? 'check-circle' : 'magic' %> me-1"></i>
          <%= talk.status?.toUpperCase() %>
        </span>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8">
      <!-- Main Talk Content -->
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body p-4">
          
          <!-- Opening Statement -->
          <% if (talk.sections?.opening) { %>
          <div class="mb-4">
            <h5 class="fw-bold text-primary"><i class="fas fa-microphone-alt me-2"></i>Opening Statement</h5>
            <div class="p-3 bg-light rounded">
              <p class="mb-0"><%= talk.sections.opening %></p>
            </div>
          </div>
          <% } %>

          <!-- Main Points -->
          <% if (talk.sections?.mainPoints && talk.sections.mainPoints.length > 0) { %>
          <div class="mb-4">
            <h5 class="fw-bold text-primary"><i class="fas fa-list-check me-2"></i>Main Safety Points</h5>
            <div class="p-3 bg-light rounded">
              <ul class="mb-0">
                <% talk.sections.mainPoints.forEach(point => { %>
                  <li class="mb-2"><%= point %></li>
                <% }) %>
              </ul>
            </div>
          </div>
          <% } %>

          <!-- Discussion Questions -->
          <% if (talk.sections?.discussionQuestions && talk.sections.discussionQuestions.length > 0) { %>
          <div class="mb-4">
            <h5 class="fw-bold text-warning"><i class="fas fa-comments me-2"></i>Discussion Questions</h5>
            <div class="p-3 bg-light rounded">
              <ul class="mb-0">
                <% talk.sections.discussionQuestions.forEach(q => { %>
                  <li class="mb-2"><i class="fas fa-circle-question text-warning me-2"></i><%= q %></li>
                <% }) %>
              </ul>
            </div>
          </div>
          <% } %>

          <!-- Supervisor Verification -->
          <% if (talk.sections?.supervisorVerification && talk.sections.supervisorVerification.length > 0) { %>
          <div class="mb-4">
            <h5 class="fw-bold text-info"><i class="fas fa-clipboard-check me-2"></i>Supervisor Verification</h5>
            <div class="p-3 bg-light rounded">
              <ul class="mb-0">
                <% talk.sections.supervisorVerification.forEach(item => { %>
                  <li class="mb-2"><%= item %></li>
                <% }) %>
              </ul>
            </div>
          </div>
          <% } %>

          <!-- Key Takeaways -->
          <% if (talk.sections?.keyTakeaways && talk.sections.keyTakeaways.length > 0) { %>
          <div class="mb-4">
            <h5 class="fw-bold text-success"><i class="fas fa-lightbulb me-2"></i>Key Takeaways</h5>
            <div class="p-3 bg-light rounded">
              <ul class="mb-0">
                <% talk.sections.keyTakeaways.forEach(takeaway => { %>
                  <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= takeaway %></li>
                <% }) %>
              </ul>
            </div>
          </div>
          <% } %>

          <!-- Closing -->
          <% if (talk.sections?.closing) { %>
          <div class="mb-4">
            <h5 class="fw-bold text-danger"><i class="fas fa-hand-peace me-2"></i>Closing Reminder</h5>
            <div class="p-3 bg-light rounded">
              <p class="mb-0"><%= talk.sections.closing %></p>
            </div>
          </div>
          <% } %>

          <!-- Full Content (fallback) -->
          <% if (!talk.sections?.opening && talk.content) { %>
          <div class="mb-4">
            <div class="p-3 bg-light rounded">
              <div style="white-space: pre-wrap;"><%= talk.content %></div>
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- AI Context (for safety officers) -->
      <% if (user.role === 'safety_officer' && talk.basedOn) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-info text-white">
          <h6 class="mb-0"><i class="fas fa-robot me-2"></i>AI Generation Context</h6>
        </div>
        <div class="card-body">
          <div class="small">
            <p class="mb-1"><strong>Based on:</strong></p>
            <ul class="small">
              <% if (talk.basedOn.recentIncidents && talk.basedOn.recentIncidents.length > 0) { %>
                <li><%= talk.basedOn.recentIncidents.length %> recent incidents</li>
              <% } %>
              <% if (talk.basedOn.identifiedHazards && talk.basedOn.identifiedHazards.length > 0) { %>
                <li><%= talk.basedOn.identifiedHazards.length %> active hazards</li>
              <% } %>
              <li>AI Model: <%= talk.aiModel || 'GPT-3.5' %></li>
            </ul>
            <% if (talk.basedOn.aiReasoning) { %>
              <p class="mb-0 text-muted"><%= talk.basedOn.aiReasoning %></p>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Inline Safety Officer Review -->
      <% if (user.role === 'safety_officer') { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header <%= talk.status === 'published' ? 'bg-success' : 'bg-warning' %> <%= talk.status === 'published' ? 'text-white' : 'text-dark' %>">
          <h5 class="mb-0 fw-bold">
            <i class="fas fa-user-shield me-2"></i>Safety Officer Review
          </h5>
        </div>
        <div class="card-body p-4">
          <% if (talk.status === 'published' && talk.review?.status === 'confirmed') { %>
            <div class="alert alert-success mb-0">
              <h6 class="fw-bold"><i class="fas fa-lock me-2"></i>Final Safety Talk Approved</h6>
              <p class="mb-0">
                This document is locked. It was approved on
                <%= new Date(talk.review.reviewedAt).toLocaleString() %>.
                The approved Word document is ready to download.
              </p>
            </div>
          <% } else { %>
            <div class="alert alert-info">
              Review the draft against actual site conditions. Add your comments and regenerate the Safety Talk until it is ready, then approve the final version.
            </div>

            <form method="POST" action="/safety-talks/<%= talk._id %>/regenerate" data-swal-confirm="true" data-swal-title="Regenerate Safety Talk?" data-swal-text="The AI will revise this Safety Talk using your safety officer comments." data-swal-confirm-button="Regenerate">
              <div class="mb-3">
                <label for="reviewComments" class="form-label fw-bold">Safety Officer Comments</label>
                <textarea
                  id="reviewComments"
                  name="reviewComments"
                  class="form-control"
                  rows="5"
                  maxlength="4000"
                  required
                  placeholder="Describe corrections, missing controls, site-specific instructions, or details the AI must incorporate."
                ></textarea>
                <div class="form-text">Comments are required and will be sent back to the AI with the current draft.</div>
              </div>
              <button type="submit" id="regenerateSafetyTalkButton" class="btn btn-warning" disabled>
                <i class="fas fa-rotate me-2"></i>Regenerate with Comments
              </button>
            </form>

            <% if (talk.review?.history?.length > 0) { %>
              <hr class="my-4">
              <form method="POST" action="/safety-talks/<%= talk._id %>/approve" data-swal-confirm="true" data-swal-title="Approve Final Safety Talk?" data-swal-text="This Safety Talk will be approved and locked. Only the final download will remain available." data-swal-confirm-button="Approve Safety Talk">
                <button type="submit" class="btn btn-success">
                  <i class="fas fa-check-circle me-2"></i>Approve Final Safety Talk
                </button>
              </form>
            <% } %>
          <% } %>

          <% if (talk.review?.history?.length > 0) { %>
            <hr class="my-4">
            <h6 class="fw-bold"><i class="fas fa-clock-rotate-left me-2"></i>Review History</h6>
            <% [...talk.review.history].reverse().forEach(entry => { %>
              <div class="border rounded p-3 mt-3 bg-light">
                <div class="small text-muted mb-2">
                  Comments used to generate version <strong><%= entry.generatedVersion %></strong>
                  on <%= new Date(entry.submittedAt).toLocaleString() %>
                </div>
                <div style="white-space: pre-wrap;"><%= entry.comments %></div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
      <% } %>

    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <!-- Actions Card -->
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="fas fa-cog me-2 text-primary"></i>Actions</h6>
          <div class="d-grid gap-2">
            <!-- <button class="btn btn-outline-secondary" onclick="window.print()">
              <i class="fas fa-print me-2"></i>Print / Save as PDF
            </button> -->
            <% if (talk.status === 'published') { %>
              <a href="/safety-talks/<%= talk._id %>/download-word" class="btn btn-outline-primary">
                <i class="fas fa-download me-2"></i>Download Word Document
              </a>
              <div class="alert alert-success py-2 mb-0">
                <i class="fas fa-check-circle me-1"></i> Approved, locked, and ready for use.
              </div>
            <% } else { %>
              <div class="alert alert-warning py-2 mb-0">
                <i class="fas fa-lock me-1"></i> Download unlocks after final approval.
              </div>
            <% } %>
            
          </div>
        </div>
      </div>

      <!-- Talk Info Card -->
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="fas fa-info-circle me-2 text-primary"></i>Talk Information</h6>
          <table class="table table-sm">
            <tr>
              <td><strong>Talk Number:</strong></td>
              <td>#<%= talk.talkNumber %></td>
            </tr>
            <tr>
              <td><strong>Duration:</strong></td>
              <td><%= talk.duration %> minutes</td>
            </tr>
            <tr>
              <td><strong>Generated:</strong></td>
              <td><%= new Date(talk.createdAt).toLocaleDateString() %></td>
            </tr>
            <tr>
              <td><strong>Status:</strong></td>
              <td><span class="badge <%= talk.status === 'published' ? 'bg-success' : talk.status === 'draft' ? 'bg-warning text-dark' : 'bg-primary' %>"><%= talk.status %></span></td>
            </tr>
            <tr>
              <td><strong>Version:</strong></td>
              <td><%= talk.version || 1 %></td>
            </tr>
            <% if (talk.review?.reviewedAt) { %>
            <tr>
              <td><strong>Reviewed:</strong></td>
              <td><%= new Date(talk.review.reviewedAt).toLocaleDateString() %></td>
            </tr>
            <% } %>
            <% if (talk.attendance?.totalAttendees > 0) { %>
            <tr>
              <td><strong>Attendees:</strong></td>
              <td><%= talk.attendance.totalAttendees %></td>
            </tr>
            <% } %>
          </table>
        </div>
      </div>

      <!-- Topics Card -->
      <% if (talk.topics && talk.topics.length > 0) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="fas fa-tags me-2 text-primary"></i>Topics Covered</h6>
          <div class="d-flex flex-wrap gap-2">
            <% talk.topics.forEach(topic => { %>
              <span class="badge bg-secondary"><%= topic %></span>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<style>
  @media print {
    .navbar, .btn, .modal, .card-header .btn, .actions-card, .no-print {
      display: none !important;
    }
    .container {
      padding: 0;
      margin: 0;
    }
    .card {
      border: none;
      box-shadow: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const comments = document.getElementById('reviewComments');
    const regenerateButton = document.getElementById('regenerateSafetyTalkButton');

    if (!comments || !regenerateButton) return;

    const updateRegenerateButton = function () {
      regenerateButton.disabled = comments.value.trim().length === 0;
    };

    comments.addEventListener('input', updateRegenerateButton);
    updateRegenerateButton();
  });
</script>

<%- include('../partials/footer') %>
