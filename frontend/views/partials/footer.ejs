<footer class="py-5" style="background: linear-gradient(135deg, #0b1c2f 0%, #1e3c5c 50%, #2c5a82 100%); position: relative; overflow: hidden;">
  <!-- Animated background elements -->
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.1; pointer-events: none;">
    <div style="position: absolute; top: 10%; left: 5%; width: 200px; height: 200px; border-radius: 50%; background: radial-gradient(circle, #e67e22 0%, transparent 70%); animation: float 8s infinite ease-in-out;"></div>
    <div style="position: absolute; bottom: 10%; right: 5%; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, #27ae60 0%, transparent 70%); animation: float 12s infinite ease-in-out reverse;"></div>
  </div>

  <div class="container position-relative">
    <div class="row g-4">
      <!-- Branding -->
      <div class="col-lg-4 mb-4 mb-lg-0">
        <div class="d-flex align-items-center mb-3">
          <div style="background: linear-gradient(135deg, #e67e22, #f39c12); width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-right: 15px; box-shadow: 0 10px 20px rgba(230, 126, 34, 0.3);">
            <i class="bi bi-shield-check fs-2 text-white"></i>
          </div>
          <h3 class="fw-bold mb-0" style="background: linear-gradient(135deg, #fff, #e67e22); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">TrueSafe</h3>
        </div>
        <p class="text-white-50 mb-3">AI-Powered Worksite Safety Intelligence Platform</p>
        
        <div class="d-flex gap-2 mb-4">
          <a href="#" class="text-white" style="width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;" onmouseover="this.style.background='#e67e22'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'">
            <i class="bi bi-facebook"></i>
          </a>
          <a href="#" class="text-white" style="width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;" onmouseover="this.style.background='#e67e22'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'">
            <i class="bi bi-twitter-x"></i>
          </a>
          <a href="#" class="text-white" style="width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;" onmouseover="this.style.background='#e67e22'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'">
            <i class="bi bi-linkedin"></i>
          </a>
          <a href="#" class="text-white" style="width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;" onmouseover="this.style.background='#e67e22'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(0)'">
            <i class="bi bi-whatsapp"></i>
          </a>
        </div>

        <div class="d-flex gap-2">
          <span class="badge px-3 py-2" style="background: linear-gradient(135deg, #27ae60, #2ecc71); box-shadow: 0 5px 15px rgba(39, 174, 96, 0.3);">
            <i class="bi bi-patch-check-fill me-1"></i>ISO 45001
          </span>
          <span class="badge px-3 py-2" style="background: linear-gradient(135deg, #3498db, #2980b9); box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);">
            <i class="bi bi-shield-fill-check me-1"></i>OSHA Compliant
          </span>
        </div>
      </div>

      <!-- Links -->
      <div class="col-lg-8">
        <div class="row g-4">
          <!-- Platform -->
          <div class="col-md-4">
            <h5 class="text-white mb-4 position-relative d-inline-block" style="border-bottom: 3px solid #e67e22; padding-bottom: 8px;">Platform</h5>
            <ul class="list-unstyled">
              <li class="mb-3">
                <a href="#features" class="text-white-50 text-decoration-none d-flex align-items-center" style="transition: all 0.3s ease;" onmouseover="this.style.color='#e67e22'; this.style.transform='translateX(5px)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'; this.style.transform='translateX(0)'">
                  <i class="bi bi-arrow-right-short me-2" style="color: #e67e22;"></i> Features
                </a>
              </li>
              <li class="mb-3">
                <a href="#pricing" class="text-white-50 text-decoration-none d-flex align-items-center" data-bs-toggle="collapse" role="button" style="transition: all 0.3s ease;" onmouseover="this.style.color='#e67e22'; this.style.transform='translateX(5px)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'; this.style.transform='translateX(0)'">
                  <i class="bi bi-arrow-right-short me-2" style="color: #e67e22;"></i> Pricing
                </a>
                <div class="collapse mt-3" id="pricing">
                  <div class="p-3 rounded" style="background: rgba(255,255,255,0.05); border-left: 3px solid #e67e22;">
                    <ul class="list-unstyled text-white-50 small">
                      <li class="mb-2"><i class="bi bi-dot me-2" style="color: #e67e22;"></i><strong>Single Site:</strong> ZMW 15,000/year</li>
                      <li class="mb-2"><i class="bi bi-dot me-2" style="color: #e67e22;"></i><strong>Multi-Site (5+):</strong> ZMW 12,000/site/year</li>
                      <li><i class="bi bi-dot me-2" style="color: #e67e22;"></i><strong>Enterprise:</strong> Custom pricing</li>
                    </ul>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <!-- Company -->
          <div class="col-md-4">
            <h5 class="text-white mb-4 position-relative d-inline-block" style="border-bottom: 3px solid #27ae60; padding-bottom: 8px;">Company</h5>
            <ul class="list-unstyled">
              <li class="mb-3">
                <a href="#aboutInfo" class="text-white-50 text-decoration-none d-flex align-items-center" data-bs-toggle="collapse" role="button" style="transition: all 0.3s ease;" onmouseover="this.style.color='#27ae60'; this.style.transform='translateX(5px)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'; this.style.transform='translateX(0)'">
                  <i class="bi bi-arrow-right-short me-2" style="color: #27ae60;"></i> About Us
                </a>
                <div class="collapse mt-3" id="aboutInfo">
                  <div class="p-3 rounded" style="background: rgba(255,255,255,0.05); border-left: 3px solid #27ae60;">
                    <p class="text-white-50 small mb-0">
                      <i class="bi bi-info-circle me-1" style="color: #27ae60;"></i>
                      TrueSafe is developed by Frontline Softwares Limited, a Zambian company dedicated to improving workplace safety through intelligent technology.
                    </p>
                  </div>
                </div>
              </li>
              <li class="mb-3">
                <a href="#contactInfo" class="text-white-50 text-decoration-none d-flex align-items-center" data-bs-toggle="collapse" role="button" style="transition: all 0.3s ease;" onmouseover="this.style.color='#27ae60'; this.style.transform='translateX(5px)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'; this.style.transform='translateX(0)'">
                  <i class="bi bi-arrow-right-short me-2" style="color: #27ae60;"></i> Contact
                </a>
                <div class="collapse mt-3" id="contactInfo">
                  <div class="p-3 rounded" style="background: rgba(255,255,255,0.05); border-left: 3px solid #27ae60;">
                    <p class="text-white-50 small mb-0">
                      <i class="bi bi-telephone-fill me-1" style="color: #27ae60;"></i> Emergency: +260 966 658181<br>
                      <i class="bi bi-telephone me-1" style="color: #27ae60;"></i> Office: +260 963 314449<br>
                      <i class="bi bi-envelope-fill me-1" style="color: #27ae60;"></i> <a href="mailto:safety@truesafe.zm" class="text-white-50 text-decoration-none">safety@truesafe.zm</a>
                    </p>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <!-- Legal -->
          <div class="col-md-4">
            <h5 class="text-white mb-4 position-relative d-inline-block" style="border-bottom: 3px solid #e74c3c; padding-bottom: 8px;">Legal</h5>
            <ul class="list-unstyled">
              <li class="mb-3">
                <a href="#privacyContent" class="text-white-50 text-decoration-none d-flex align-items-center" data-bs-toggle="collapse" role="button" style="transition: all 0.3s ease;" onmouseover="this.style.color='#e74c3c'; this.style.transform='translateX(5px)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'; this.style.transform='translateX(0)'">
                  <i class="bi bi-arrow-right-short me-2" style="color: #e74c3c;"></i> Privacy
                </a>
                <div class="collapse mt-3" id="privacyContent">
                  <div class="p-3 rounded" style="background: rgba(255,255,255,0.05); border-left: 3px solid #e74c3c;">
                    <p class="text-white-50 small mb-0">
                      <i class="bi bi-shield-lock-fill me-1" style="color: #e74c3c;"></i>
                      Worker reports are completely anonymous. We collect only safety-critical data and never share personal information with third parties.
                    </p>
                  </div>
                </div>
              </li>
              <li class="mb-3">
                <a href="#compliance" class="text-white-50 text-decoration-none d-flex align-items-center" data-bs-toggle="collapse" role="button" style="transition: all 0.3s ease;" onmouseover="this.style.color='#e74c3c'; this.style.transform='translateX(5px)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'; this.style.transform='translateX(0)'">
                  <i class="bi bi-arrow-right-short me-2" style="color: #e74c3c;"></i> Compliance
                </a>
                <div class="collapse mt-3" id="compliance">
                  <div class="p-3 rounded" style="background: rgba(255,255,255,0.05); border-left: 3px solid #e74c3c;">
                    <p class="text-white-50 small mb-0">
                      <i class="bi bi-patch-check-fill me-1" style="color: #e74c3c;"></i>
                      Fully compliant with Zambian Factories Act, OSHA standards, and ISO 45001 requirements. Regular third-party audits.
                    </p>
                  </div>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <hr class="my-5" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); height: 2px; border: none;">

    <div class="row">
      <div class="col-12">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
          <p class="mb-3 mb-md-0 text-white-50 small">
            <i class="bi bi-c-circle me-1"></i> <%= new Date().getFullYear() %> TrueSafe by Frontline Softwares. All rights reserved.
          </p>
          <div class="d-flex gap-3">
            <a href="#" class="text-white-50 small text-decoration-none" style="transition: color 0.3s ease;" onmouseover="this.style.color='#e67e22'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Terms</a>
            <span class="text-white-50">|</span>
            <a href="#" class="text-white-50 small text-decoration-none" style="transition: color 0.3s ease;" onmouseover="this.style.color='#e67e22'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Privacy</a>
            <span class="text-white-50">|</span>
            <a href="#" class="text-white-50 small text-decoration-none" style="transition: color 0.3s ease;" onmouseover="this.style.color='#e67e22'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Cookies</a>
          </div>
          <div class="mt-3 mt-md-0">
            <span class="badge" style="background: linear-gradient(135deg, #e67e22, #f39c12); padding: 8px 15px;">
              <i class="bi bi-shield-fill-check me-1"></i> Safety First, Always
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.1); }
  }
  
  @media (max-width: 768px) {
    .footer .col-md-4 {
      margin-bottom: 2rem;
    }
  }
</style>

<!-- Bootstrap Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Flash message alerts -->
<script>
  <% if (typeof success !== 'undefined' && success.length > 0) { %>
    Swal.fire({
      icon: 'success',
      title: 'Success!',
      text: "<%= success[0] %>",
      timer: 3000,
      showConfirmButton: true
    });
  <% } %>

  <% if (typeof error !== 'undefined' && error.length > 0) { %>
    Swal.fire({
      icon: 'error',
      title: 'Oops!',
      text: "<%= error[0] %>",
      timer: 3000,
      showConfirmButton: true
    });
  <% } %>
</script>

</body>
</html>