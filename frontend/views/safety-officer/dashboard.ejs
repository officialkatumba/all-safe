<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-5">
  <!-- Header with Profile Summary -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 bg-gradient-primary text-white" style="background: linear-gradient(135deg, #1e3c5c 0%, #2c5a82 100%);">
        <div class="card-body p-4">
          <div class="row align-items-center">
            <div class="col-md-8">
              <h2 class="display-5 fw-bold mb-2">
                <i class="fas fa-shield-alt me-2"></i>Safety Officer Dashboard
              </h2>
              <p class="lead mb-0">
                Welcome back, <strong><%= user.safetyOfficer?.name || user.email %></strong>
              </p>
              <p class="mb-0 mt-2">
                <span class="badge bg-warning text-dark p-2">
                  <i class="fas fa-id-card me-1"></i> Officer #<%= user.safetyOfficer?.officerNumber || 'N/A' %>
                </span>
                
                <% 
                let verificationBadge = '⏳ Pending Verification';
                let badgeClass = 'bg-info';
                if (user.safetyOfficer?.verificationStatus === 'verified') {
                  verificationBadge = '✓ Verified';
                  badgeClass = 'bg-success';
                }
                %>
                
                <span class="badge <%= badgeClass %> ms-2 p-2">
                  <i class="fas fa-certificate me-1"></i> <%= verificationBadge %>
                </span>
              </p>
            </div>
            <div class="col-md-4 text-center text-md-end">
              <div class="profile-image-container">
                <img src="<%= user.safetyOfficer?.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>" alt="Profile" class="rounded-circle border border-3 border-white shadow" style="width: 120px; height: 120px; object-fit: cover;">
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Safety Summary Cards -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4" style="color: #1e3c5c">
            <i class="fas fa-chart-line me-2"></i>Safety Performance Overview
          </h4>
          <div class="row g-3">
            <!-- Worksites Managed -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);">
                  <i class="fas fa-hard-hat fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.worksitesManaged || 0 %></h3>
                  <small class="text-muted">Worksites Managed</small>
                </div>
              </div>
            </div>

            <!-- Incidents Reported -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);">
                  <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.incidentsReported || 0 %></h3>
                  <small class="text-muted">Incidents</small>
                </div>
              </div>
            </div>

            <!-- Safety Talks -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);">
                  <i class="fas fa-chalkboard-teacher fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.safetyTalksConducted || 0 %></h3>
                  <small class="text-muted">Safety Talks</small>
                </div>
              </div>
            </div>

            <!-- Compliance Score -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);">
                  <i class="fas fa-shield-alt fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">98%</h3>
                  <small class="text-muted">Compliance Score</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Dashboard Action Cards - First Row -->
  <div class="row g-4">
    <!-- Worksite Management -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-hard-hat fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Worksite Management</h5>
          <p class="card-text text-muted mb-4">Create and manage worksites, track hazards, and monitor safety conditions</p>
          <div class="d-grid gap-2">
            <a href="/worksites/my-worksites" class="btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none;">
              <i class="fas fa-list me-1"></i> View Worksites
            </a>
            <a href="/worksites/create" class="btn btn-outline-primary">
              <i class="fas fa-plus-circle me-1"></i> Add New Worksite
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Incident Reporting -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-exclamation-circle fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Incident Management</h5>
          <p class="card-text text-muted mb-4">Review and manage incident reports, track near-misses, and analyze trends</p>
          <div class="d-grid gap-2">
            <a href="/incidents/reported" class="btn" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border: none;">
              <i class="fas fa-list-alt me-1"></i> View Incidents
            </a>
            <a href="/incidents/report" class="btn btn-outline-danger">
              <i class="fas fa-flag me-1"></i> Report Incident
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Safety Talks -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-chalkboard-teacher fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Safety Talks</h5>
          <p class="card-text text-muted mb-4">Generate and manage daily safety briefings and toolbox talks</p>
          <div class="d-grid gap-2">
            <a href="/safety-talks" class="btn" style="background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%); color: white; border: none;">
              <i class="fas fa-calendar-alt me-1"></i> View All Talks
            </a>
            <a href="/safety-talks/generate" class="btn btn-outline-success">
              <i class="fas fa-robot me-1"></i> Generate New Talk
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Dashboard Action Cards - Second Row -->
  <div class="row g-4 mt-2">
    <!-- PPE Compliance -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-helmet-safety fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">PPE Compliance</h5>
          <p class="card-text text-muted mb-4">Monitor PPE requirements and track compliance across worksites</p>
          <div class="d-grid gap-2">
            <a href="/ppe/requirements" class="btn" style="background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%); color: white; border: none;">
              <i class="fas fa-clipboard-check me-1"></i> View Requirements
            </a>
            <a href="/ppe/checklist" class="btn btn-outline-warning">
              <i class="fas fa-check-double me-1"></i> Compliance Check
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Risk Assessment -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-chart-pie fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Risk Assessment</h5>
          <p class="card-text text-muted mb-4">Analyze risks, generate assessment reports, and track mitigation</p>
          <div class="d-grid gap-2">
            <a href="/risk-assessments" class="btn" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); color: #1e3c5c; border: none;">
              <i class="fas fa-chart-bar me-1"></i> View Assessments
            </a>
            <a href="/risk-assessments/new" class="btn btn-outline-info">
              <i class="fas fa-plus me-1"></i> New Assessment
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Compliance Reports -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-file-pdf fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Compliance Reports</h5>
          <p class="card-text text-muted mb-4">Generate and download compliance documentation for audits</p>
          <div class="d-grid gap-2">
            <a href="/compliance/reports" class="btn" style="background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%); color: #1e3c5c; border: none;">
              <i class="fas fa-file-alt me-1"></i> View Reports
            </a>
            <a href="/compliance/generate" class="btn btn-outline-secondary">
              <i class="fas fa-download me-1"></i> Generate Report
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="row mt-5">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3" style="color: #1e3c5c">
            <i class="fas fa-bolt me-2"></i>Quick Actions
          </h5>
          <div class="row g-2">
            <div class="col-md-3 col-6">
              <a href="/safety-officers/edit" class="btn btn-outline-primary w-100">
                <i class="fas fa-user-edit me-1"></i> Edit Profile
              </a>
            </div>
            <div class="col-md-3 col-6">
              <a href="/worksites/create" class="btn btn-outline-success w-100">
                <i class="fas fa-plus-circle me-1"></i> New Worksite
              </a>
            </div>
            <div class="col-md-3 col-6">
              <a href="/incidents/report" class="btn btn-outline-danger w-100">
                <i class="fas fa-flag me-1"></i> Report Incident
              </a>
            </div>
            <div class="col-md-3 col-6">
              <a href="/safety-talks/generate" class="btn btn-outline-info w-100">
                <i class="fas fa-robot me-1"></i> Generate Talk
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
  }
  
  .icon-circle {
    transition: transform 0.3s ease;
  }
  
  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }
  
  .btn {
    transition: all 0.3s ease;
  }
  
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
</style>

<%- include('../partials/footer') %>