<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TrueSafe365 | AI-Powered Hazard Pattern Discovery</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
</head>

<body>

<main class="truesafe365-landing" data-landing>
  <!-- HERO SCREEN -->
  <section class="ts-screen ts-screen-hero is-active" id="welcome" aria-labelledby="TrueSafe365-title">
    <div class="ts-orb ts-orb-one"></div>
    <div class="ts-orb ts-orb-two"></div>
    <div class="ts-orb ts-orb-three"></div>

    <nav class="ts-topbar" aria-label="Landing navigation">
      <a class="ts-mini-brand" href="/" aria-label="TrueSafe365 home">
        <span class="ts-mark"><i class="bi bi-shield-check"></i></span>
        <span>TrueSafe365</span>
      </a>

      <button class="ts-menu-toggle" type="button" data-menu-toggle aria-label="Open navigation">
        <i class="bi bi-list"></i>
      </button>

      <div class="ts-nav-links" data-mobile-menu>
        <% if (user) { %>
          <a href="/dashboard/officer">Dashboard</a>
          <a href="/api/users/logout">Sign out</a>
        <% } else { %>
          <a href="/api/users/login">Sign in</a>
          <a href="/register/safety-officer">Register</a>
        <% } %>
      </div>
    </nav>

    <div class="ts-hero-center">
      <p class="ts-eyebrow">WHAT YOU MISS IS CAUSING YOUR NEXT EXTREME ACCIDENT</p>
      <h1 id="TrueSafe365-title">Expose Hidden Risks. Prevent Catastrophe.</h1>

      <p class="ts-hero-copy">
        Isolated near-misses and scattered field logs hide deadly patterns that human eyes overlook. <strong>TrueSafe365</strong> uses AI to analyze your work areas and continuous daily site feeds, uncovering complex hazard links before they trigger devastating loss of life, destroyed equipment, and ruinous operational downtime.
      </p>

      <button class="ts-primary-action" type="button" data-go-onboarding>
        See How It Works
        <i class="bi bi-arrow-right-short"></i>
      </button>
    </div>

    <div class="ts-home-video">
      <div class="ts-video-frame">
        <iframe
          src="https://www.youtube-nocookie.com/embed/s6XWkHzuJ2g?rel=0&modestbranding=1&playsinline=1"
          title="Safety video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </div>

    <div class="ts-floating-note ts-note-left">
      <span>Stop Loss</span>
      Prevent Fatalities &amp; Equipment Damage
    </div>

    <div class="ts-floating-note ts-note-right">
      <span>$0 Costly Delays</span>
      Eliminate Crippling Downtime
    </div>

    <footer class="ts-legal-links" aria-label="Legal links">
      <a href="#">Privacy Notice</a>
      <a href="#">Terms &amp; Privacy</a>
      <a href="#">Third Party Notices</a>
    </footer>
  </section>

  <!-- ONBOARDING/HOW IT WORKS SCREEN -->
  <section class="ts-screen ts-screen-onboarding" id="onboarding" aria-labelledby="onboarding-title">
    <div class="ts-orb ts-orb-four"></div>
    <div class="ts-orb ts-orb-five"></div>

    <nav class="ts-topbar" aria-label="Onboarding navigation">
      <a class="ts-mini-brand" href="/" aria-label="TrueSafe365 home">
        <span class="ts-mark"><i class="bi bi-shield-check"></i></span>
        <span>TrueSafe365</span>
      </a>

      <button class="ts-menu-toggle" type="button" data-menu-toggle aria-label="Open navigation">
        <i class="bi bi-list"></i>
      </button>

      <div class="ts-nav-links" data-mobile-menu>
        <a href="/">Home</a>
        <% if (user) { %>
          <a href="/dashboard/officer">Dashboard</a>
          <a href="/api/users/logout">Sign out</a>
        <% } else { %>
          <a href="/api/users/login">Sign in</a>
          <a href="/register/safety-officer">Register</a>
        <% } %>
      </div>
    </nav>

    <div class="ts-onboarding-wrap">
      <div class="ts-onboarding-intro">
        <p class="ts-eyebrow">The Predictive Safety Blueprint</p>
        <h2 id="onboarding-title">
          Human intuition gathers data. AI reveals patterns. You retain full control. <span aria-hidden="true">🎯</span>
        </h2>
      </div>

      <div class="ts-path-panel" aria-label="TrueSafe365 system operational steps">
        <a class="ts-path-action" href="/register/safety-officer">
          Deploy Your Shield Now
          <i class="bi bi-arrow-up-right"></i>
        </a>

        <ol class="ts-path-list">
          <li>
            <span>01</span>
            <div>
              <strong>Secure Your Officer Command Portal</strong>
              <p>Create your exclusive Safety Officer profile. You have absolute standalone control over your projects, workspace parameters, and data logs with zero corporate friction.</p>
            </div>
          </li>

          <li>
            <span>02</span>
            <div>
              <strong>Map Your Active Work Areas</strong>
              <p>Define your specific dynamic operating locations—whether it's an excavation sector, a high-voltage assembly site, or a processing facility where risk changes by the hour.</p>
            </div>
          </li>

          <li>
            <span>03</span>
            <div>
              <strong>Profile Site Environments &amp; Machinery</strong>
              <p>Input critical task descriptions, operational realities, handling equipment profiles, and personnel footprints so the background baseline is completely precise.</p>
            </div>
          </li>

          <li>
            <span>04</span>
            <div>
              <strong>Feed Continuous Raw Incident Data</strong>
              <p>Dump real-time field information directly into your terminal—including verbal worker updates, minor slips, near-miss entries, or messy site WhatsApp logs. Nothing gets lost.</p>
            </div>
          </li>

          <li>
            <span>05</span>
            <div>
              <strong>Unleash AI Critical Threat Analysis</strong>
              <p>Let the AI run cross-pattern processing across your historical site data. It immediately drafts bulletproof Risk Assessments, customized Toolbox Talks, and meticulous Safety Audits focused on the patterns humans miss.</p>
            </div>
          </li>

          <li>
            <span>06</span>
            <div>
              <strong>Human Sign-Off: Edit, Approve &amp; Deploy</strong>
              <p>You are the ultimate authority. Tweak, edit, or append the generated text layouts right on your screen to match exact localized compliance requirements, then export clean, editable Word documents.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>
</main>

<style>
  :root {
    --ts-ink: #0f172a;
    --ts-muted: #475569;
    --ts-surface: rgba(255, 255, 255, 0.74);
    --ts-line: rgba(225, 29, 72, 0.15);
    --ts-blue: #1d4ed8;
    --ts-green: #047857;
    --ts-orange: #d97706;
    --ts-red: #dc2626;
    --ts-red-dark: #991b1b;
    --ts-clinical: #fef2f2;
    --ts-shadow: 0 28px 80px rgba(220, 38, 38, 0.1);
  }

  body {
    background: #fffcfc;
    overflow-x: hidden;
  }

  .truesafe365-landing {
    color: var(--ts-ink);
    font-family: "Plus Jakarta Sans", "Inter", system-ui, sans-serif;
    min-height: 100vh;
  }

  .ts-screen {
    display: none;
    isolation: isolate;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(1.2rem, 3vw, 2rem);
    position: relative;
  }

  .ts-screen.is-active {
    animation: tsScreenIn 0.55s ease both;
    display: block;
  }

  .ts-screen-hero {
    background:
      radial-gradient(circle at 16% 18%, rgba(220, 38, 38, 0.12), transparent 27rem),
      radial-gradient(circle at 82% 22%, rgba(255, 255, 255, 0.95), transparent 30rem),
      linear-gradient(135deg, #ffffff 0%, #fff5f5 48%, #f8faff 100%);
  }

  .ts-screen-onboarding {
    background:
      radial-gradient(circle at 12% 12%, rgba(220, 38, 38, 0.12), transparent 22rem),
      radial-gradient(circle at 90% 20%, rgba(255, 255, 255, 0.9), transparent 24rem),
      linear-gradient(135deg, #fff 0%, #fff8f8 100%);
  }

  .ts-topbar {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1180px;
    position: relative;
    z-index: 20;
  }

  .ts-mini-brand,
  .ts-nav-links a {
    align-items: center;
    color: var(--ts-ink);
    display: inline-flex;
    font-weight: 800;
    gap: 0.55rem;
    text-decoration: none;
  }

  .ts-nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: flex-end;
  }

  .ts-mark {
    align-items: center;
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 1rem;
    box-shadow: 0 12px 34px rgba(220, 38, 38, 0.1);
    color: var(--ts-red);
    display: inline-flex;
    height: 2.7rem;
    justify-content: center;
    width: 2.7rem;
    font-size: 1.3rem;
  }

  .ts-nav-links a {
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid var(--ts-line);
    border-radius: 999px;
    box-shadow: 0 10px 30px rgba(23, 32, 51, 0.05);
    padding: 0.8rem 1.4rem;
    font-size: 0.95rem;
    font-weight: 700;
    transition: all 0.2s ease;
  }

  .ts-nav-links a:hover {
    background: var(--ts-red);
    color: #fff;
    border-color: var(--ts-red);
  }

  .ts-menu-toggle {
    align-items: center;
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 0.9rem;
    box-shadow: 0 10px 30px rgba(23, 32, 51, 0.08);
    color: var(--ts-red);
    cursor: pointer;
    display: none;
    font-size: 1.7rem;
    height: 2.8rem;
    justify-content: center;
    width: 2.8rem;
  }

  .ts-hero-center {
    align-items: center;
    display: flex;
    flex-direction: column;
    margin: clamp(4rem, 10vh, 7rem) auto 0;
    max-width: 1050px;
    min-height: 52vh;
    position: relative;
    text-align: center;
    z-index: 2;
  }

  .ts-eyebrow {
    background: #fff0f0;
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: 999px;
    box-shadow: 0 14px 40px rgba(220, 38, 38, 0.06);
    color: var(--ts-red-dark);
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    margin-bottom: 1.5rem;
    padding: 0.62rem 1.2rem;
    text-transform: uppercase;
  }

  .ts-hero-center h1 {
    font-family: "Space Grotesk", "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2.3rem, 7.5vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.05;
    margin: 0;
    padding-right: 0.1em;
    text-wrap: balance;
  }

  .ts-hero-copy {
    color: var(--ts-muted);
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    line-height: 1.6;
    margin: 2rem auto 2.2rem;
    max-width: 820px;
  }

  .ts-primary-action {
    align-items: center;
    background: var(--ts-red);
    border: 0;
    border-radius: 999px;
    box-shadow: 0 18px 45px rgba(220, 38, 38, 0.25);
    color: #fff;
    display: inline-flex;
    font-size: 1.1rem;
    font-weight: 800;
    gap: 0.4rem;
    padding: 1.1rem 1.7rem 1.1rem 2rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .ts-primary-action:hover {
    box-shadow: 0 24px 60px rgba(220, 38, 38, 0.35);
    transform: translateY(-3px);
    background: var(--ts-red-dark);
  }

  .ts-primary-action i {
    font-size: 1.6rem;
  }

  .ts-orb {
    border-radius: 999px;
    filter: blur(2px);
    opacity: 0.85;
    position: absolute;
    z-index: 0;
  }

  .ts-orb-one {
    animation: tsFloat 8s ease-in-out infinite;
    background: #ffe4e6;
    height: 12rem;
    left: 6%;
    top: 20%;
    width: 12rem;
  }

  .ts-orb-two {
    animation: tsFloat 10s ease-in-out infinite reverse;
    background: #ffffff;
    height: 16rem;
    right: 8%;
    top: 15%;
    width: 16rem;
  }

  .ts-orb-three {
    animation: tsFloat 12s ease-in-out infinite;
    background: #fee2e2;
    bottom: 8%;
    height: 18rem;
    left: 28%;
    width: 18rem;
  }

  .ts-orb-four {
    background: #fee2e2;
    height: 22rem;
    left: -8rem;
    top: 12rem;
    width: 22rem;
  }

  .ts-orb-five {
    background: #ffedd5;
    bottom: -7rem;
    right: -7rem;
    height: 24rem;
    width: 24rem;
  }

  .ts-floating-note {
    backdrop-filter: blur(18px);
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: 1.5rem;
    box-shadow: var(--ts-shadow);
    color: var(--ts-ink);
    font-weight: 700;
    max-width: 260px;
    padding: 1.1rem 1.3rem;
    position: absolute;
    z-index: 2;
    font-size: 0.95rem;
  }

  .ts-floating-note span {
    color: var(--ts-red);
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .ts-note-left {
    bottom: 18%;
    left: 5%;
    transform: rotate(-3deg);
  }

  .ts-note-right {
    right: 5%;
    top: 42%;
    transform: rotate(3deg);
  }

  .ts-home-video {
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 2.2rem;
    box-shadow: 0 30px 90px rgba(220, 38, 38, 0.15);
    margin: clamp(3rem, 8vh, 6rem) auto 3rem;
    max-width: 980px;
    overflow: hidden;
    padding: clamp(0.65rem, 1.8vw, 1rem);
    position: relative;
    z-index: 2;
  }

  .ts-video-frame {
    aspect-ratio: 16 / 9;
    background: #0f172a;
    border-radius: 1.55rem;
    overflow: hidden;
    width: 100%;
  }

  .ts-video-frame iframe {
    border: 0;
    height: 100%;
    width: 100%;
  }

  .ts-legal-links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    justify-content: center;
    margin: 2rem auto 0;
    max-width: 720px;
    padding: 1rem 0 0.25rem;
    position: relative;
    z-index: 2;
  }

  .ts-legal-links a {
    color: var(--ts-muted);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .ts-legal-links a:hover {
    color: var(--ts-red);
  }

  .ts-onboarding-wrap {
    margin: clamp(3rem, 7vh, 5.5rem) auto 0;
    max-width: 1180px;
    position: relative;
    z-index: 2;
  }

  .ts-onboarding-intro {
    max-width: 820px;
  }

  .ts-onboarding-intro h2 {
    font-family: "Space Grotesk", "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2.1rem, 5.2vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1.3rem;
  }

  .ts-path-panel {
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.92);
    border-radius: 2rem;
    box-shadow: 0 24px 75px rgba(220, 38, 38, 0.08);
    margin: 2rem 0;
    overflow: hidden;
    padding: clamp(1rem, 3vw, 1.6rem);
    position: relative;
  }

  .ts-path-action {
    align-items: center;
    background: var(--ts-red);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-weight: 800;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.5rem;
    text-decoration: none;
    box-shadow: 0 10px 25px rgba(220, 38, 38, 0.2);
    transition: all 0.2s ease;
  }

  .ts-path-action:hover {
    color: #fff;
    transform: translateY(-2px);
    background: var(--ts-red-dark);
    box-shadow: 0 12px 30px rgba(220, 38, 38, 0.3);
  }

  .ts-path-list {
    display: grid;
    gap: 0.95rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ts-path-list li {
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(220, 38, 38, 0.08);
    border-radius: 1.35rem;
    display: grid;
    gap: 1.2rem;
    grid-template-columns: auto 1fr;
    padding: 1.2rem;
    transition: all 0.2s ease;
  }

  .ts-path-list li:hover {
    background: #fff;
    box-shadow: 0 16px 44px rgba(220, 38, 38, 0.08);
    transform: translateX(6px);
    border-color: rgba(220, 38, 38, 0.2);
  }

  .ts-path-list span {
    align-items: center;
    background: linear-gradient(135deg, var(--ts-red), var(--ts-red-dark));
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    height: 3rem;
    justify-content: center;
    width: 3rem;
  }

  .ts-path-list strong {
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .ts-path-list p {
    color: var(--ts-muted);
    font-size: 0.98rem;
    line-height: 1.6;
    margin: 0;
  }

  @keyframes tsFloat {
    0%, 100% {
      transform: translate3d(0, 0, 0) scale(1);
    }

    50% {
      transform: translate3d(0, -15px, 0) scale(1.03);
    }
  }

  @keyframes tsScreenIn {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.995);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 992px) {
    .ts-floating-note {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .ts-menu-toggle {
      display: inline-flex;
    }

    .ts-nav-links {
      background: rgba(255, 255, 255, 0.98);
      border: 1px solid var(--ts-line);
      border-radius: 1.2rem;
      box-shadow: 0 24px 70px rgba(220, 38, 38, 0.15);
      display: none;
      flex-direction: column;
      min-width: 220px;
      padding: 0.85rem;
      position: absolute;
      right: 0;
      top: calc(100% + 0.75rem);
      z-index: 999;
    }

    .ts-nav-links.show {
      display: flex;
    }

    .ts-nav-links a {
      justify-content: center;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .ts-screen {
      padding: 1rem;
    }

    .ts-hero-center {
      margin-top: 3.5rem;
      min-height: auto;
    }

    .ts-hero-center h1 {
      font-size: clamp(2.2rem, 12vw, 3.8rem);
      letter-spacing: -0.04em;
    }

    .ts-hero-copy {
      font-size: 1rem;
    }

    .ts-onboarding-intro h2 {
      font-size: clamp(1.9rem, 10vw, 3rem);
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const hero = document.querySelector(".ts-screen-hero");
    const onboarding = document.querySelector(".ts-screen-onboarding");
    const goOnboardingButton = document.querySelector("[data-go-onboarding]");

    const showScreen = function (screen, hash) {
      hero.classList.remove("is-active");
      onboarding.classList.remove("is-active");
      screen.classList.add("is-active");
      window.history.replaceState(null, "", hash || window.location.pathname);
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    const showOnboarding = function () {
      showScreen(onboarding, "#onboarding");
    };

    const showHero = function () {
      showScreen(hero, window.location.pathname);
    };

    const syncScreenFromHash = function () {
      if (window.location.hash === "#onboarding") {
        showOnboarding();
      } else {
        showHero();
      }
    };

    document.querySelectorAll("[data-menu-toggle]").forEach(function (toggle) {
      toggle.addEventListener("click", function () {
        const nav = toggle.closest(".ts-topbar").querySelector("[data-mobile-menu]");
        nav.classList.toggle("show");
      });
    });

    document.addEventListener("click", function (event) {
      document.querySelectorAll(".ts-topbar").forEach(function (topbar) {
        if (!topbar.contains(event.target)) {
          const nav = topbar.querySelector("[data-mobile-menu]");
          nav?.classList.remove("show");
        }
      });
    });

    syncScreenFromHash();

    goOnboardingButton?.addEventListener("click", showOnboarding);
    window.addEventListener("hashchange", syncScreenFromHash);
  });
</script>

</body>
</html>