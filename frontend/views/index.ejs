<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TrueSafe365 | AI Safety Intelligence</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
</head>

<body>

<main class="truesafe365-landing" data-landing>
  <section class="ts-screen ts-screen-hero is-active" id="welcome" aria-labelledby="TrueSafe365-title">
    <div class="ts-orb ts-orb-one"></div>
    <div class="ts-orb ts-orb-two"></div>
    <div class="ts-orb ts-orb-three"></div>

    <nav class="ts-topbar" aria-label="Landing navigation">
      <a class="ts-mini-brand" href="/" aria-label="TrueSafe365 home">
        <span class="ts-mark"><i class="bi bi-shield-check"></i></span>
        <span>TrueSafe365</span>
      </a>

      <button class="ts-menu-toggle" type="button" data-menu-toggle aria-label="Open navigation">
        <i class="bi bi-list"></i>
      </button>

      <div class="ts-nav-links" data-mobile-menu>
        <% if (user) { %>
          <a href="/dashboard/officer">Dashboard</a>
          <a href="/api/users/logout">Sign out</a>
        <% } else { %>
          <a href="/api/users/login">Sign in</a>
          <a href="/register/safety-officer">Register</a>
        <% } %>
      </div>
    </nav>

    <div class="ts-hero-center">
      <p class="ts-eyebrow">Stop starting safety from an empty canvas</p>
      <h1 id="TrueSafe365-title">TrueSafe365</h1>

      <p class="ts-hero-copy">
        Safety officers are expected to imagine every accident, delay, fine, injury, equipment failure, and production stoppage before it happens. TrueSafe365 starts from your site description and real safety data, then uses AI to predict what ordinary paperwork can miss.
      </p>

      <button class="ts-primary-action" type="button" data-go-onboarding>
        How it Works
        <i class="bi bi-arrow-right-short"></i>
      </button>
    </div>

    <div class="ts-home-video">
      <div class="ts-video-frame">
        <iframe
          src="https://www.youtube-nocookie.com/embed/s6XWkHzuJ2g?rel=0&modestbranding=1&playsinline=1"
          title="Safety video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </div>

    <div class="ts-floating-note ts-note-left">
      <span>Risk</span>
      Predict before it costs you
    </div>

    <div class="ts-floating-note ts-note-right">
      <span>1000x</span>
      One officer, amplified
    </div>

    <footer class="ts-legal-links" aria-label="Legal links">
      <a href="#">Privacy Notice</a>
      <a href="#">Terms &amp; Privacy</a>
      <a href="#">Third Party Notices</a>
    </footer>
  </section>

  <section class="ts-screen ts-screen-onboarding" id="onboarding" aria-labelledby="onboarding-title">
    <div class="ts-orb ts-orb-four"></div>
    <div class="ts-orb ts-orb-five"></div>

    <nav class="ts-topbar" aria-label="Onboarding navigation">
      <a class="ts-mini-brand" href="/" aria-label="TrueSafe365 home">
        <span class="ts-mark"><i class="bi bi-shield-check"></i></span>
        <span>TrueSafe365</span>
      </a>

      <button class="ts-menu-toggle" type="button" data-menu-toggle aria-label="Open navigation">
        <i class="bi bi-list"></i>
      </button>

      <div class="ts-nav-links" data-mobile-menu>
        <a href="/">Home</a>
        <% if (user) { %>
          <a href="/dashboard/officer">Dashboard</a>
          <a href="/api/users/logout">Sign out</a>
        <% } else { %>
          <a href="/api/users/login">Sign in</a>
          <a href="/register/safety-officer">Register</a>
        <% } %>
      </div>
    </nav>

    <div class="ts-onboarding-wrap">
      <div class="ts-onboarding-intro">
        <p class="ts-eyebrow">Welcome to TrueSafe365</p>
        <h2 id="onboarding-title">
          Giving 1 safety officer the power of 1000 Skilled safety officers <span aria-hidden="true">💪</span>
        </h2>
      </div>

      <div class="ts-path-panel" aria-label="TrueSafe365 onboarding steps">
        <a class="ts-path-action" href="/register/safety-officer">
          Start onboarding
          <i class="bi bi-arrow-up-right"></i>
        </a>

        <ol class="ts-path-list">
          <li>
            <span>01</span>
            <div>
              <strong>Register on the system</strong>
              <p>Create the safety officer account that will own the work areas and documents.</p>
            </div>
          </li>

          <li>
            <span>02</span>
            <div>
              <strong>Create a work area</strong>
              <p>Add the site, department, project, or operating area where safety risk must be managed.</p>
            </div>
          </li>

          <li>
            <span>03</span>
            <div>
              <strong>Describe the activities correctly</strong>
              <p>Tell TrueSafe365 what work is being done, who is exposed, what equipment is used, and what could go wrong.</p>
            </div>
          </li>

          <li>
            <span>04</span>
            <div>
              <strong>Identify hazards and controls</strong>
              <p>Capture known hazards, site conditions, emergency readiness, PPE needs, and worker concerns.</p>
            </div>
          </li>

          <li>
            <span>05</span>
            <div>
              <strong>Ask AI for professional drafts</strong>
              <p>Generate safety documents such as risk assessments, JSA, safety talks, PPE, permits, audits, training, emergency plans, and environmental screenings.</p>
            </div>
          </li>

          <li>
            <span>06</span>
            <div>
              <strong>Correct, approve, and download</strong>
              <p>Add officer comments, regenerate where needed, approve the final version, then download the approved Word document.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>
</main>

<style>
  :root {
    --ts-ink: #1f2937;
    --ts-muted: #667085;
    --ts-surface: rgba(255, 255, 255, 0.74);
    --ts-line: rgba(190, 18, 60, 0.14);
    --ts-blue: #2563eb;
    --ts-green: #059669;
    --ts-orange: #ff9f1c;
    --ts-red: #e11d48;
    --ts-red-dark: #be123c;
    --ts-clinical: #fff5f7;
    --ts-shadow: 0 28px 80px rgba(190, 18, 60, 0.12);
  }

  body {
    background: #fffafa;
    overflow-x: hidden;
  }

  .truesafe365-landing {
    color: var(--ts-ink);
    font-family: "Plus Jakarta Sans", "Inter", system-ui, sans-serif;
    min-height: 100vh;
  }

  .ts-screen {
    display: none;
    isolation: isolate;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(1.2rem, 3vw, 2rem);
    position: relative;
  }

  .ts-screen.is-active {
    animation: tsScreenIn 0.55s ease both;
    display: block;
  }

  .ts-screen-hero {
    background:
      radial-gradient(circle at 16% 18%, rgba(225, 29, 72, 0.14), transparent 27rem),
      radial-gradient(circle at 82% 22%, rgba(255, 255, 255, 0.92), transparent 30rem),
      linear-gradient(135deg, #ffffff 0%, #fff1f4 48%, #f8fbff 100%);
  }

  .ts-screen-onboarding {
    background:
      radial-gradient(circle at 12% 12%, rgba(225, 29, 72, 0.14), transparent 22rem),
      radial-gradient(circle at 90% 20%, rgba(255, 255, 255, 0.9), transparent 24rem),
      linear-gradient(135deg, #fff 0%, #fff5f7 100%);
  }

  .ts-topbar {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1180px;
    position: relative;
    z-index: 20;
  }

  .ts-mini-brand,
  .ts-nav-links a {
    align-items: center;
    color: var(--ts-ink);
    display: inline-flex;
    font-weight: 700;
    gap: 0.55rem;
    text-decoration: none;
  }

  .ts-nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: flex-end;
  }

  .ts-mark {
    align-items: center;
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 1rem;
    box-shadow: 0 12px 34px rgba(23, 32, 51, 0.1);
    color: var(--ts-red);
    display: inline-flex;
    height: 2.7rem;
    justify-content: center;
    width: 2.7rem;
  }

  .ts-nav-links a {
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid var(--ts-line);
    border-radius: 999px;
    box-shadow: 0 10px 30px rgba(23, 32, 51, 0.08);
    padding: 0.8rem 1.15rem;
  }

  .ts-nav-links a:hover {
    background: var(--ts-red);
    color: #fff;
  }

  .ts-menu-toggle {
    align-items: center;
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 0.9rem;
    box-shadow: 0 10px 30px rgba(23, 32, 51, 0.08);
    color: var(--ts-red);
    cursor: pointer;
    display: none;
    font-size: 1.7rem;
    height: 2.8rem;
    justify-content: center;
    width: 2.8rem;
  }

  .ts-hero-center {
    align-items: center;
    display: flex;
    flex-direction: column;
    margin: clamp(5rem, 12vh, 9rem) auto 0;
    max-width: 1050px;
    min-height: 58vh;
    position: relative;
    text-align: center;
    z-index: 2;
  }

  .ts-eyebrow {
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid rgba(23, 32, 51, 0.1);
    border-radius: 999px;
    box-shadow: 0 14px 40px rgba(23, 32, 51, 0.08);
    color: #31415c;
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    margin-bottom: 1.5rem;
    padding: 0.62rem 1rem;
    text-transform: uppercase;
  }

  .ts-hero-center h1 {
    font-family: "Space Grotesk", "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2.5rem, 9vw, 7.75rem);
    font-weight: 700;
    letter-spacing: -0.08em;
    line-height: 0.9;
    margin: 0;
    padding-right: 0.1em;
    text-wrap: balance;
  }

  .ts-hero-copy {
    color: var(--ts-muted);
    font-size: clamp(1.05rem, 2vw, 1.45rem);
    line-height: 1.55;
    margin: 2rem auto 1.8rem;
    max-width: 760px;
  }

  .ts-primary-action {
    align-items: center;
    background: var(--ts-red);
    border: 0;
    border-radius: 999px;
    box-shadow: 0 18px 45px rgba(23, 32, 51, 0.22);
    color: #fff;
    display: inline-flex;
    font-size: 1.04rem;
    font-weight: 800;
    gap: 0.35rem;
    padding: 1rem 1.45rem 1rem 1.7rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .ts-primary-action:hover {
    box-shadow: 0 24px 60px rgba(23, 32, 51, 0.3);
    transform: translateY(-3px);
  }

  .ts-primary-action i {
    font-size: 1.6rem;
  }

  .ts-orb {
    border-radius: 999px;
    filter: blur(1px);
    opacity: 0.9;
    position: absolute;
    z-index: 0;
  }

  .ts-orb-one {
    animation: tsFloat 8s ease-in-out infinite;
    background: #fecdd3;
    height: 12rem;
    left: 8%;
    top: 22%;
    width: 12rem;
  }

  .ts-orb-two {
    animation: tsFloat 10s ease-in-out infinite reverse;
    background: #ffffff;
    height: 16rem;
    right: 9%;
    top: 17%;
    width: 16rem;
  }

  .ts-orb-three {
    animation: tsFloat 12s ease-in-out infinite;
    background: #fee2e2;
    bottom: 10%;
    height: 18rem;
    left: 32%;
    width: 18rem;
  }

  .ts-orb-four {
    background: #cce2ff;
    height: 22rem;
    left: -8rem;
    top: 12rem;
    width: 22rem;
  }

  .ts-orb-five {
    background: #ffe0a3;
    bottom: -7rem;
    height: 24rem;
    right: -7rem;
    width: 24rem;
  }

  .ts-floating-note {
    backdrop-filter: blur(18px);
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 1.5rem;
    box-shadow: var(--ts-shadow);
    color: #34425d;
    font-weight: 800;
    padding: 1rem 1.15rem;
    position: absolute;
    z-index: 2;
  }

  .ts-floating-note span {
    color: var(--ts-blue);
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.7rem;
    line-height: 1;
  }

  .ts-note-left {
    bottom: 17%;
    left: 8%;
    transform: rotate(-4deg);
  }

  .ts-note-right {
    right: 8%;
    top: 46%;
    transform: rotate(4deg);
  }

  .ts-home-video {
    background: #fff;
    border: 1px solid rgba(225, 29, 72, 0.14);
    border-radius: 2.2rem;
    box-shadow: 0 30px 90px rgba(190, 18, 60, 0.16);
    margin: clamp(4rem, 9vh, 7rem) auto 3rem;
    max-width: 980px;
    overflow: hidden;
    padding: clamp(0.65rem, 1.8vw, 1rem);
    position: relative;
    z-index: 2;
  }

  .ts-video-frame {
    aspect-ratio: 16 / 9;
    background: #0a0f1d;
    border-radius: 1.55rem;
    overflow: hidden;
    width: 100%;
  }

  .ts-video-frame iframe {
    border: 0;
    height: 100%;
    width: 100%;
  }

  .ts-legal-links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    justify-content: center;
    margin: 2rem auto 0;
    max-width: 720px;
    padding: 1rem 0 0.25rem;
    position: relative;
    z-index: 2;
  }

  .ts-legal-links a {
    color: var(--ts-muted);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .ts-legal-links a:hover {
    color: var(--ts-red);
  }

  .ts-onboarding-wrap {
    margin: clamp(3rem, 7vh, 5.5rem) auto 0;
    max-width: 1180px;
    position: relative;
    z-index: 2;
  }

  .ts-onboarding-intro {
    max-width: 760px;
  }

  .ts-onboarding-intro h2 {
    font-family: "Space Grotesk", "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2.25rem, 5.8vw, 4.75rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1;
    margin-bottom: 1.3rem;
  }

  .ts-path-panel {
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.92);
    border-radius: 2rem;
    box-shadow: 0 24px 75px rgba(23, 32, 51, 0.12);
    margin: 2rem 0;
    overflow: hidden;
    padding: clamp(1rem, 3vw, 1.6rem);
    position: relative;
  }

  .ts-path-action {
    align-items: center;
    background: var(--ts-red);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-weight: 800;
    gap: 0.35rem;
    margin-bottom: 1.2rem;
    padding: 0.95rem 1.25rem;
    text-decoration: none;
  }

  .ts-path-action:hover {
    color: #fff;
    transform: translateY(-3px);
  }

  .ts-path-list {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ts-path-list li {
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(23, 32, 51, 0.08);
    border-radius: 1.35rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: auto 1fr;
    padding: 1rem;
  }

  .ts-path-list li:hover {
    background: #fff;
    box-shadow: 0 16px 44px rgba(23, 32, 51, 0.1);
    transform: translateX(6px);
  }

  .ts-path-list span {
    align-items: center;
    background: linear-gradient(135deg, var(--ts-red), var(--ts-red-dark));
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    height: 3rem;
    justify-content: center;
    width: 3rem;
  }

  .ts-path-list strong {
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.28rem;
    letter-spacing: -0.035em;
    margin-bottom: 0.25rem;
  }

  .ts-path-list p {
    color: var(--ts-muted);
    font-size: 0.96rem;
    line-height: 1.55;
    margin: 0;
  }

  @keyframes tsFloat {
    0%, 100% {
      transform: translate3d(0, 0, 0) scale(1);
    }

    50% {
      transform: translate3d(0, -18px, 0) scale(1.04);
    }
  }

  @keyframes tsScreenIn {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.99);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 900px) {
    .ts-floating-note {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .ts-menu-toggle {
      display: inline-flex;
    }

    .ts-nav-links {
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid var(--ts-line);
      border-radius: 1.2rem;
      box-shadow: 0 24px 70px rgba(23, 32, 51, 0.18);
      display: none;
      flex-direction: column;
      min-width: 220px;
      padding: 0.85rem;
      position: absolute;
      right: 0;
      top: calc(100% + 0.75rem);
      z-index: 999;
    }

    .ts-nav-links.show {
      display: flex;
    }

    .ts-nav-links a {
      justify-content: center;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .ts-screen {
      padding: 1rem;
    }

    .ts-hero-center {
      margin-top: 4rem;
      min-height: auto;
    }

    .ts-hero-center h1 {
      font-size: clamp(2.8rem, 14vw, 4.5rem);
      letter-spacing: -0.06em;
    }

    .ts-hero-copy {
      font-size: 1rem;
    }

    .ts-onboarding-intro h2 {
      font-size: clamp(2.35rem, 11vw, 3.4rem);
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const hero = document.querySelector(".ts-screen-hero");
    const onboarding = document.querySelector(".ts-screen-onboarding");
    const goOnboardingButton = document.querySelector("[data-go-onboarding]");

    const showScreen = function (screen, hash) {
      hero.classList.remove("is-active");
      onboarding.classList.remove("is-active");
      screen.classList.add("is-active");
      window.history.replaceState(null, "", hash || window.location.pathname);
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    const showOnboarding = function () {
      showScreen(onboarding, "#onboarding");
    };

    const showHero = function () {
      showScreen(hero, window.location.pathname);
    };

    const syncScreenFromHash = function () {
      if (window.location.hash === "#onboarding") {
        showOnboarding();
      } else {
        showHero();
      }
    };

    document.querySelectorAll("[data-menu-toggle]").forEach(function (toggle) {
      toggle.addEventListener("click", function () {
        const nav = toggle.closest(".ts-topbar").querySelector("[data-mobile-menu]");
        nav.classList.toggle("show");
      });
    });

    document.addEventListener("click", function (event) {
      document.querySelectorAll(".ts-topbar").forEach(function (topbar) {
        if (!topbar.contains(event.target)) {
          const nav = topbar.querySelector("[data-mobile-menu]");
          nav?.classList.remove("show");
        }
      });
    });

    syncScreenFromHash();

    goOnboardingButton?.addEventListener("click", showOnboarding);
    window.addEventListener("hashchange", syncScreenFromHash);
  });
</script>

</body>
</html>