<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); border-radius: 20px;">
        <div class="card-body p-4 text-white">
          <div class="d-flex align-items-center mb-2">
            <i class="fas fa-user-cog fa-2x me-3"></i>
            <div>
              <h2 class="display-5 fw-bold mb-0">Manage Safety Officers</h2>
              <p class="lead mb-0"><%= workArea.name %></p>
            </div>
          </div>
          <div class="mt-3">
            <a href="/work-areas/<%= workArea._id %>" class="btn btn-light btn-sm">
              <i class="fas fa-arrow-left me-2"></i>Back to Work Area
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Two Column Layout -->
  <div class="row g-4">
    <!-- Currently Assigned -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-lg h-100" style="border-radius: 20px;">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h4 class="fw-bold mb-0" style="color: #26a69a">
            <i class="fas fa-user-check me-2"></i>Currently Assigned
          </h4>
        </div>
        <div class="card-body p-4">
          <% if (workArea.assignedSafetyOfficers && workArea.assignedSafetyOfficers.filter(a => a.isActive !== false).length > 0) { %>
            <div class="list-group">
              <% workArea.assignedSafetyOfficers.filter(a => a.isActive !== false).forEach(assignment => { %>
              <div class="list-group-item border-0 bg-light mb-2 rounded-3">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="fw-bold mb-1"><%= assignment.officer?.name || 'Unknown' %></h6>
                    <div class="d-flex gap-2 align-items-center">
                      <span class="badge" style="background: #26a69a; color: white;">
                        <i class="fas fa-clock me-1"></i> <%= assignment.shift || 'Not set' %>
                      </span>
                      <% if (assignment.isPrimary) { %>
                      <span class="badge" style="background: #ffc107; color: #212529;">
                        <i class="fas fa-crown me-1"></i> Primary
                      </span>
                      <% } %>
                    </div>
                  </div>
                  <button class="btn btn-sm btn-outline-danger remove-officer" data-assignment-id="<%= assignment._id %>">
                    <i class="fas fa-times"></i>
                  </button>
                </div>
              </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-5">No safety officers assigned yet</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Assignment Form -->
    <div class="col-lg-7">
      <div class="card border-0 shadow-lg" style="border-radius: 20px;">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h4 class="fw-bold mb-0" style="color: #26a69a">
            <i class="fas fa-user-plus me-2"></i>Assign New Officer
          </h4>
        </div>
        <div class="card-body p-4">
          <form id="assignOfficerForm">
            <div class="row g-4">
              <div class="col-md-8">
                <label class="form-label fw-semibold">Select Officer</label>
                <select class="form-select form-select-lg" id="officerSelect" required>
                  <option value="">Choose officer...</option>
                  <% availableOfficers.forEach(officer => { %>
                  <option value="<%= officer._id %>"><%= officer.name %> (<%= officer.officerNumber %>)</option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-semibold">Shift</label>
                <select class="form-select form-select-lg" id="shiftSelect" required>
                  <option value="morning">Morning</option>
                  <option value="afternoon">Afternoon</option>
                  <option value="night">Night</option>
                </select>
              </div>
              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="isPrimaryCheck">
                  <label class="form-check-label" for="isPrimaryCheck">
                    Set as Primary Officer for this shift
                  </label>
                </div>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-lg w-100 py-3" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); color: white; border: none; border-radius: 50px;">
                  <i class="fas fa-user-plus me-2"></i>Assign Officer
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const workAreaId = '<%= workArea._id %>';

  // Handle assign officer
  document.getElementById('assignOfficerForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const officerId = document.getElementById('officerSelect').value;
    const shift = document.getElementById('shiftSelect').value;
    const isPrimary = document.getElementById('isPrimaryCheck').checked;

    fetch(`/work-areas/${workAreaId}/assign-officer`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ officerId, shift, isPrimary })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        window.location.reload();
      } else {
        alert('Error: ' + data.message);
      }
    })
    .catch(err => {
      console.error('Error assigning officer:', err);
      alert('Error assigning officer');
    });
  });

  // Handle remove officer
  document.querySelectorAll('.remove-officer').forEach(btn => {
    btn.addEventListener('click', function() {
      const assignmentId = this.dataset.assignmentId;
      
      if (!confirm('Remove this officer from the work area?')) return;

      fetch(`/work-areas/${workAreaId}/assignments/${assignmentId}`, {
        method: 'DELETE'
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          window.location.reload();
        } else {
          alert('Error: ' + data.message);
        }
      })
      .catch(err => {
        console.error('Error removing officer:', err);
        alert('Error removing officer');
      });
    });
  });
});
</script>

<%- include('../partials/footer') %>