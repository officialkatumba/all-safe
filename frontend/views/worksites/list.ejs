<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <!-- Header - Redesigned to match work area style -->
    <div class="row mb-4">
      <div class="col-12">
        <div class="card border-0 overflow-hidden" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); border-radius: 24px;">
          <div class="card-body p-0">
            <div class="row g-0">
              <div class="col-lg-8 p-4">
                <div class="d-flex align-items-center mb-3">
                  <div class="bg-white bg-opacity-20 p-3 rounded-3 me-3" style="backdrop-filter: blur(10px); border-radius: 16px;">
                    <i class="fas fa-hard-hat fa-2x text-white"></i>
                  </div>
                  <div>
                    <h1 class="fw-bold text-white mb-1" style="font-size: 2rem;">All Worksites</h1>
                    <p class="text-white-50 mb-0">Manage and monitor all your worksites</p>
                  </div>
                </div>
                
                <div class="d-flex flex-wrap align-items-center gap-2">
                  <span class="badge px-3 py-2" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; border-radius: 40px;">
                    <i class="fas fa-chart-line me-1"></i> <%= worksites.length %> Total
                  </span>
                  <span class="badge px-3 py-2" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; border-radius: 40px;">
                    <i class="fas fa-check-circle me-1"></i> <%= worksites.filter(w => w.status === 'active').length %> Active
                  </span>
                  <a href="/worksites/create" class="btn btn-light btn-sm" style="border-radius: 40px;">
                    <i class="fas fa-plus-circle me-2"></i>New Worksite
                  </a>
                </div>
                
                <p class="mt-3 text-white-50 small mb-0">
                  <i class="fas fa-user me-1"></i> Welcome back, <strong><%= user.safetyOfficer?.name || user.email %></strong>
                </p>
              </div>
              
              <div class="col-lg-4 bg-dark bg-opacity-25 p-4 d-flex align-items-center justify-content-center">
                <img src="<%= user.safetyOfficer?.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>" 
                     alt="Profile" 
                     class="rounded-circle border border-3 border-white shadow"
                     style="width: 100px; height: 100px; object-fit: cover;">
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Search & Filter Bar -->
    <div class="row mb-4">
      <div class="col-12">
        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
          <div class="card-body p-3">
            <form method="GET" class="row g-2">
              <div class="col-md-6">
                <div class="input-group">
                  <span class="input-group-text bg-light border-0">
                    <i class="fas fa-search text-muted"></i>
                  </span>
                  <input type="text" class="form-control border-0 bg-light" name="search" 
                         placeholder="Search worksites..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                </div>
              </div>
              <div class="col-md-3">
                <select class="form-select border-0 bg-light" name="status">
                  <option value="">All Status</option>
                  <option value="active" <%= typeof status !== 'undefined' && status === 'active' ? 'selected' : '' %>>Active</option>
                  <option value="inactive" <%= typeof status !== 'undefined' && status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                  <option value="under_review" <%= typeof status !== 'undefined' && status === 'under_review' ? 'selected' : '' %>>Under Review</option>
                  <option value="completed" <%= typeof status !== 'undefined' && status === 'completed' ? 'selected' : '' %>>Completed</option>
                </select>
              </div>
              <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); border: none; border-radius: 40px;">
                  <i class="fas fa-filter me-1"></i> Filter
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Worksites Table -->
    <% if (worksites && worksites.length > 0) { %>
    <div class="row">
      <div class="col-12">
        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="px-4 py-3" style="border-radius: 16px 0 0 0;">Worksite</th>
                    <th class="py-3">Location</th>
                    <th class="py-3 text-center" style="border-radius: 0 16px 0 0;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% worksites.forEach(worksite => { %>
                  <tr class="hover-row">
                    <td class="px-4">
                      <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-primary bg-opacity-10 p-2 me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                          <i class="fas fa-hard-hat" style="color: #2196f3;"></i>
                        </div>
                        <div>
                          <div class="d-flex align-items-center gap-2 flex-wrap">
                            <strong><%= worksite.name %></strong>
                            <span class="badge <%= 
                              worksite.status === 'active' ? 'bg-success' : 
                              worksite.status === 'inactive' ? 'bg-secondary' : 
                              worksite.status === 'under_review' ? 'bg-warning text-dark' : 
                              'bg-info' 
                            %>" style="border-radius: 40px;"><%= worksite.status %></span>
                            <span class="badge bg-light text-dark" style="border-radius: 40px;">
                              <i class="fas fa-hashtag me-1"></i> <%= worksite.worksiteNumber %>
                            </span>
                          </div>
                          <div class="d-flex align-items-center gap-3 mt-1 flex-wrap">
                            <small class="text-muted">
                              <i class="fas fa-tag me-1" style="color: #2196f3;"></i> <%= worksite.siteType %>
                            </small>
                            <small class="text-muted">
                              <i class="fas fa-layer-group me-1" style="color: #26a69a;"></i> <%= worksite.workAreas?.length || 0 %> areas
                            </small>
                            <small class="text-muted">
                              <i class="fas fa-users me-1" style="color: #ff9800;"></i> <%= worksite.assignedSafetyOfficers?.length || 0 %> officers
                            </small>
                            <small class="text-muted">
                              <i class="fas fa-chart-line me-1" style="color: #4caf50;"></i> <%= worksite.performance?.overallSafetyScore || 100 %>% score
                            </small>
                          </div>
                          <% if (worksite.description) { %>
                          <small class="text-muted d-block mt-1">
                            <i class="fas fa-align-left me-1"></i> <%= worksite.description.substring(0, 60) %><%= worksite.description.length > 60 ? '...' : '' %>
                          </small>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td>
                      <i class="fas fa-map-marker-alt me-1" style="color: #f44336;"></i>
                      <%= worksite.location %>
                    </td>
                    <td class="text-center">
                      <div class="d-flex gap-2 justify-content-center">
                        <a href="/worksites/<%= worksite._id %>" class="btn btn-sm btn-outline-primary" title="View" style="border-radius: 40px;">
                          <i class="fas fa-eye"></i>
                        </a>
                        <a href="/worksites/<%= worksite._id %>/edit" class="btn btn-sm btn-outline-secondary" title="Edit" style="border-radius: 40px;">
                          <i class="fas fa-edit"></i>
                        </a>
                        <div class="dropdown">
                          <button class="btn btn-sm btn-outline-info dropdown-toggle" type="button" data-bs-toggle="dropdown" style="border-radius: 40px;">
                            <i class="fas fa-plus"></i>
                          </button>
                          <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/work-areas/create?worksiteId=<%= worksite._id %>"><i class="fas fa-map-marked-alt me-2"></i>Add Work Area</a></li>
                            <li><a class="dropdown-item" href="/incidents/report?worksiteId=<%= worksite._id %>"><i class="fas fa-flag me-2"></i>Report Incident</a></li>
                            <li><a class="dropdown-item" href="/safety-talks/generate?worksiteId=<%= worksite._id %>"><i class="fas fa-robot me-2"></i>Generate Talk</a></li>
                          </ul>
                        </div>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Pagination -->
    <% if (pagination && pagination.pages > 1) { %>
    <div class="row mt-5">
      <div class="col-12">
        <nav aria-label="Worksites pagination">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page - 1 %>&search=<%= search || '' %>&status=<%= status || '' %>" style="border-radius: 40px;">
                <i class="fas fa-chevron-left"></i>
              </a>
            </li>
            
            <% for (let i = 1; i <= pagination.pages; i++) { %>
              <% if (i >= pagination.page - 2 && i <= pagination.page + 2) { %>
              <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %>&search=<%= search || '' %>&status=<%= status || '' %>" style="border-radius: 40px;">
                  <%= i %>
                </a>
              </li>
              <% } %>
            <% } %>
            
            <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page + 1 %>&search=<%= search || '' %>&status=<%= status || '' %>" style="border-radius: 40px;">
                <i class="fas fa-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
    <% } %>
    
    <% } else { %>
    <!-- Empty State - Redesigned -->
    <div class="row">
      <div class="col-12">
        <div class="card border-0 bg-light" style="border-radius: 24px;">
          <div class="card-body text-center p-5">
            <div class="mb-4">
              <i class="fas fa-hard-hat fa-4x text-muted"></i>
            </div>
            <h3 class="fw-bold mb-3">No Worksites Found</h3>
            <p class="text-muted mb-4">
              <%= search || status ? 'No worksites match your search criteria.' : 'Get started by creating your first worksite.' %>
            </p>
            <% if (search || status) { %>
            <a href="/worksites/my-worksites" class="btn btn-outline-primary btn-lg px-4" style="border-radius: 40px;">
              <i class="fas fa-redo-alt me-2"></i> Clear Filters
            </a>
            <% } else { %>
            <a href="/worksites/create" class="btn btn-primary btn-lg px-4" 
               style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); border: none; border-radius: 40px;">
              <i class="fas fa-plus-circle me-2"></i> Create First Worksite
            </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</div>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }
  
  .hover-row {
    transition: background-color 0.2s ease;
  }
  .hover-row:hover {
    background-color: #f8f9ff;
  }
  
  .page-link {
    color: #2196f3;
    border-radius: 40px;
    margin: 0 2px;
  }
  .page-item.active .page-link {
    background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
    border-color: #1976d2;
    color: white;
  }
  
  .dropdown-menu {
    border: none;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    border-radius: 16px;
    padding: 0.5rem;
  }
  
  .dropdown-item {
    border-radius: 40px;
    padding: 0.5rem 1rem;
    margin: 2px 0;
  }
  
  .dropdown-item:hover {
    background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
    color: white;
  }
  
  .dropdown-item i {
    width: 20px;
  }
  
  .table th {
    font-weight: 600;
    color: #495057;
  }
  
  .bg-opacity-20 {
    background: rgba(255,255,255,0.2);
  }
  
  .btn {
    transition: all 0.2s ease;
  }
  
  .btn:hover {
    transform: translateY(-2px);
  }
</style>

<%- include('../partials/footer') %>