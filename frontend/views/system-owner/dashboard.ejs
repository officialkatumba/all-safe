<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h3 class="fw-bold mb-1">System Owner Dashboard</h3>
      <p class="text-muted mb-0">Client usage, platform activity, and monetization indicators.</p>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#recentUsagePanel">
        <i class="fas fa-clock me-1"></i> Recent Activity
      </button>
      <a href="/alerts" class="btn btn-outline-danger btn-sm">
        <i class="fas fa-bell me-1"></i> Alerts
      </a>
    </div>
  </div>

  <div class="owner-summary mb-4">
    <% [
      ['Companies', stats.companies, 'building', '#e67e22'],
      ['Users', stats.users, 'users', '#1e3c5c'],
      ['Active Users', stats.activeUsers, 'user-check', '#27ae60'],
      ['Worksites', stats.worksites, 'hard-hat', '#8e44ad'],
      ['Incidents', stats.incidents, 'exclamation-triangle', '#e74c3c'],
      ['AI Generations', stats.aiGenerations, 'robot', '#2980b9']
    ].forEach(item => { %>
      <div class="owner-metric" style="--metric-color: <%= item[3] %>;">
        <i class="fas fa-<%= item[2] %>"></i>
        <span><%= item[0] %></span>
        <strong><%= item[1] %></strong>
      </div>
    <% }) %>
  </div>

  <div class="collapse mb-4" id="recentUsagePanel">
    <div class="recent-panel">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0">Recent Activity</h5>
        <span class="small text-muted"><%= recentUsage.length %> latest events</span>
      </div>
      <% if (!recentUsage.length) { %>
        <div class="text-muted">No usage events yet.</div>
      <% } %>
      <% recentUsage.forEach(event => { %>
        <div class="recent-item">
          <div class="fw-semibold"><%= event.description || event.eventType %></div>
          <div class="small text-muted">
            <%= event.company?.companyName || event.user?.email || 'System' %> |
            <%= event.module || 'general' %> |
            <%= new Date(event.createdAt).toLocaleString() %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="client-table">
    <div class="d-flex justify-content-between align-items-center px-3 py-3 border-bottom flex-wrap gap-2">
      <div>
        <h5 class="fw-bold mb-0">Registered Companies</h5>
        <div class="small text-muted">Company-level clients and early billing signals.</div>
      </div>
      <span class="badge text-bg-light"><%= companyList.length %> shown</span>
    </div>

    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Company</th>
            <th>Plan</th>
            <th>Status</th>
            <th>Users</th>
            <th>Incidents</th>
            <th>AI Use</th>
            <th>Joined</th>
          </tr>
        </thead>
        <tbody>
          <% if (!companyList.length) { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">No registered companies yet.</td>
            </tr>
          <% } %>
          <% companyList.forEach(company => { %>
            <tr>
              <td>
                <div class="fw-semibold"><%= company.companyName || company.name || 'Unnamed company' %></div>
                <div class="small text-muted"><%= company.email %></div>
              </td>
              <td><span class="badge text-bg-primary"><%= company.subscription?.plan || 'pilot' %></span></td>
              <td>
                <span class="badge bg-<%= company.isActive ? 'success' : 'secondary' %>">
                  <%= company.subscription?.status || (company.isActive ? 'active' : 'paused') %>
                </span>
              </td>
              <td><%= company.userCount || 0 %></td>
              <td>
                <a href="/incidents" class="text-decoration-none fw-semibold">
                  <%= company.incidentCount || 0 %>
                </a>
              </td>
              <td><%= company.aiGenerationCount || 0 %></td>
              <td><%= new Date(company.createdAt).toLocaleDateString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .owner-summary {
    background: linear-gradient(135deg, #1e3c5c 0%, #276749 45%, #e67e22 100%);
    border-radius: 8px;
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    overflow: hidden;
  }

  .owner-metric {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    min-height: 104px;
    padding: 1rem;
  }

  .owner-metric i {
    color: var(--metric-color);
    display: block;
    font-size: 1.35rem;
    margin-bottom: 0.45rem;
  }

  .owner-metric span {
    display: block;
    font-size: 0.78rem;
    opacity: 0.88;
  }

  .owner-metric strong {
    display: block;
    font-size: 1.75rem;
    line-height: 1.1;
  }

  .recent-panel,
  .client-table {
    background: #fff;
    border: 1px solid rgba(30, 60, 92, 0.1);
    border-radius: 8px;
    box-shadow: 0 10px 24px rgba(30, 42, 58, 0.08);
  }

  .recent-panel {
    padding: 1rem;
  }

  .recent-item {
    border-top: 1px solid #edf2f7;
    padding: 0.8rem 0;
  }

  .recent-item:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .client-table thead {
    background: #f8fafc;
    color: #1e3c5c;
  }

  @media (max-width: 992px) {
    .owner-summary {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 576px) {
    .owner-summary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

<%- include('../partials/footer') %>
