<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="card shadow-lg border-0" style="border-radius: 20px;">
    <div class="card-header" style="background: linear-gradient(135deg, #f093fb, #f5576c); color: white;">
      <h4 class="mb-0"><i class="fas fa-file-signature me-2"></i>Work Permit #<%= permit.permitNumber %></h4>
      <p class="mb-0 small opacity-75"><%= permit.title %> | <%= permit.workArea?.name %></p>
    </div>
    <div class="card-body p-4">
      <div class="row">
        <div class="col-md-8">
          <div class="mb-3">
            <strong>Permit Type:</strong>
            <span class="badge bg-primary ms-2"><%= permit.permitType?.replace(/_/g, ' ') %></span>
          </div>
          <div class="mb-3">
            <strong>Work Description:</strong>
            <p class="mt-1"><%= permit.workDescription %></p>
          </div>
          <div class="mb-3">
            <strong>Valid Period:</strong>
            <p><%= new Date(permit.validFrom).toLocaleString() %> → <%= new Date(permit.validTo).toLocaleString() %></p>
          </div>

          <!-- Pre-work Checklist -->
          <div class="card mb-3">
            <div class="card-header bg-light">
              <strong><i class="fas fa-check-circle me-2 text-success"></i>Pre-Work Checklist</strong>
            </div>
            <div class="card-body">
              <div class="list-group">
                <% permit.preWorkChecklist.forEach((item, idx) => { %>
                  <div class="list-group-item">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" <%= item.completed ? 'checked' : '' %> disabled>
                      <label class="form-check-label"><%= item.item %></label>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>

          <!-- PPE Requirements -->
          <div class="card mb-3">
            <div class="card-header bg-light">
              <strong><i class="fas fa-helmet-safety me-2 text-warning"></i>PPE Requirements</strong>
            </div>
            <div class="card-body">
              <table class="table table-sm">
                <thead><tr><th>Item</th><th>Quantity</th><th>Condition</th></tr></thead>
                <tbody>
                  <% permit.ppeRequirements.forEach(ppe => { %>
                    <tr><td><%= ppe.item?.replace(/_/g, ' ') %></td><td><%= ppe.quantity %></td><td><%= ppe.condition %></td></tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Hazards and Controls -->
          <% if (permit.hazards && permit.hazards.length > 0) { %>
          <div class="card mb-3">
            <div class="card-header bg-light">
              <strong><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Hazards & Controls</strong>
            </div>
            <div class="card-body">
              <% permit.hazards.forEach(hazard => { %>
                <div class="mb-3">
                  <strong><%= hazard.hazard %></strong>
                  <ul class="mt-1 mb-0">
                    <% hazard.controls?.forEach(control => { %>
                      <li><%= control %></li>
                    <% }) %>
                  </ul>
                </div>
              <% }) %>
            </div>
          </div>
          <% } %>

          <!-- Emergency Procedures -->
          <% if (permit.emergencyProcedures) { %>
          <div class="card mb-3">
            <div class="card-header bg-light">
              <strong><i class="fas fa-ambulance me-2 text-danger"></i>Emergency Procedures</strong>
            </div>
            <div class="card-body">
              <p><%= permit.emergencyProcedures %></p>
            </div>
          </div>
          <% } %>
        </div>

        <div class="col-md-4">
          <!-- Status Card -->
          <div class="card mb-3">
            <div class="card-body text-center">
              <h5>Status</h5>
              <span class="badge <%= 
                permit.status === 'active' ? 'bg-success' : 
                permit.status === 'issued' ? 'bg-info' : 
                permit.status === 'completed' ? 'bg-primary' : 
                permit.status === 'expired' ? 'bg-danger' : 
                'bg-warning' 
              %> fs-6 p-2"><%= permit.status?.toUpperCase() %></span>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="card">
            <div class="card-body">
              <h6 class="fw-bold mb-3">Actions</h6>
              <div class="d-grid gap-2">
                <% if (permit.status === 'pending_approval' && user.role === 'safety_officer') { %>
                  <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#approveModal">
                    <i class="fas fa-check-circle me-2"></i>Approve Permit
                  </button>
                <% } %>
                <% if (permit.status === 'issued' && user.role === 'safety_officer') { %>
                  <form method="POST" action="/permits/<%= permit._id %>/activate">
                    <button type="submit" class="btn btn-primary w-100">
                      <i class="fas fa-play me-2"></i>Activate Permit
                    </button>
                  </form>
                <% } %>
                <% if (permit.status === 'active' && user.role === 'safety_officer') { %>
                  <button class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#completeModal">
                    <i class="fas fa-check-double me-2"></i>Complete Permit
                  </button>
                <% } %>
                <button class="btn btn-secondary" onclick="window.print()">
                  <i class="fas fa-print me-2"></i>Print Permit
                </button>
                <a href="/work-areas/<%= permit.workArea?._id %>" class="btn btn-outline-secondary">
                  <i class="fas fa-arrow-left me-2"></i>Back to Work Area
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title">Approve Permit</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/permits/<%= permit._id %>/approve">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Comments</label>
            <textarea name="comments" class="form-control" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success">Approve</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Complete Modal -->
<div class="modal fade" id="completeModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-warning text-dark">
        <h5 class="modal-title">Complete Permit</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/permits/<%= permit._id %>/complete">
        <div class="modal-body">
          <div class="form-check mb-2">
            <input type="checkbox" name="workCompleted" value="yes" class="form-check-input" id="workCompleted">
            <label class="form-check-label" for="workCompleted">Work completed</label>
          </div>
          <div class="form-check mb-2">
            <input type="checkbox" name="areaLeftSafe" value="yes" class="form-check-input" id="areaLeftSafe">
            <label class="form-check-label" for="areaLeftSafe">Area left safe</label>
          </div>
          <div class="form-check mb-2">
            <input type="checkbox" name="equipmentRemoved" value="yes" class="form-check-input" id="equipmentRemoved">
            <label class="form-check-label" for="equipmentRemoved">Equipment removed</label>
          </div>
          <div class="form-check mb-2">
            <input type="checkbox" name="wasteDisposed" value="yes" class="form-check-input" id="wasteDisposed">
            <label class="form-check-label" for="wasteDisposed">Waste disposed properly</label>
          </div>
          <div class="mb-3">
            <label class="form-label">Remarks</label>
            <textarea name="remarks" class="form-control" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-warning">Complete</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>