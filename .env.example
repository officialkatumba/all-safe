# TrueSafe365 local development environment example
# Copy to .env for local development and replace placeholders.

NODE_ENV=development
BASE_URL=http://localhost:5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/truesafe365
SESSION_SECRET=replace-with-long-random-string

OPENAI_API_KEY=sk-replace-with-your-key

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=alerts@example.com
EMAIL_PASS=replace-with-email-app-password
EMAIL_SECURE=false
SAFETY_ALERT_EMAILS=safety@example.com
SYSTEM_OWNER_EMAILS=owner@example.com

# Optional seed script only
SEED_OFFICER_EMAIL=safety.officer@example.com
SEED_OFFICER_PASSWORD=replace-with-dev-only-password
SEED_OFFICER_NAME=TrueSafe365 Safety Officer
